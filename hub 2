function orParseCSV(results){
  var rows=results.data, seen=new Set(), out=[];
  rows.forEach(function(r){
    // Only accept rows where the GMB link column (col 0) is a real Google Maps URL
    // This automatically skips headers, blank rows, and junk rows
    var gmb=(r[0]||'').trim();
    if(!gmb.startsWith('http')) return;

    var name=(r[1]||'').trim();
    if(!name||name.length<2) return;

    // Deduplicate on phone then name
    var phone=(r[10]||'').trim();
    var key=phone||name;
    if(seen.has(key)) return;
    seen.add(key);

    var rev=parseInt((r[3]||'').replace(/[^0-9]/g,''))||0;
    var rawSite=(r[11]||'').trim();
    var hasSite=rawSite.startsWith('http')&&
      rawSite.indexOf('googleadservices')<0&&
      rawSite.indexOf('pagead')<0;
    var rating=parseFloat((r[2]||'').replace(/[^0-9.]/g,''))||0;

    var lead={
      gmb:gmb,
      name:name,
      rating:rating,
      reviews:rev,
      type:(r[4]||'').replace(/[·⋅•]/g,'').trim(),
      address:(r[6]||'').trim(),
      openStatus:(r[7]||'').trim(),
      hours:(r[8]||'').replace(/[\u202f⋅·\u00b7]/g,' ').replace(/^\s*[·•\-]\s*/,'').trim(),
      phone:phone,
      website:hasSite?rawSite:'',
      snippet:(r[17]||'').replace(/^"|"$/g,'').trim(),
      auto:[],
      status:'pending'
    };
    lead.auto=orAutoDetect(lead);
    out.push(lead);
  });
  return out;
}

