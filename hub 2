function dashUpdatePipeline(){
  var msgs=dashPipe.messages;
  var reps=dashPipe.replies;
  var auds=dashPipe.audits;
  var cld=dashPipe.closed;
  // Reply rate
  var rr=document.getElementById('dpipe-rate-replies');
  if(rr)rr.textContent=msgs>0?Math.round(reps/msgs*100)+'% reply rate':'';
  // Audit rate
  var ar=document.getElementById('dpipe-rate-audits');
  if(ar)ar.textContent=reps>0?Math.round(auds/reps*100)+'% to call':'';
  // Close rate
  var cr=document.getElementById('dpipe-rate-closed');
  if(cr)cr.textContent=auds>0?Math.round(cld/auds*100)+'% close rate':'';
