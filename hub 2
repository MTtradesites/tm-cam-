    } else {
      gap.textContent = '';
    }
  }

  if(!count && !rating && !reply){ if(sum) sum.style.display='none'; return; }
  var lines = [];
  if(count){
    var cc = count>=20?'var(--gr)':count>=10?'var(--am)':'var(--rd)';
    lines.push('<span style="color:'+cc+';font-weight:600;">'+count+' reviews</span> — '+(count>=20?'solid volume':'needs more — target is 20+'));
  }
  if(rating){
    var rc = rating>=4.5?'var(--gr)':rating>=4.0?'var(--am)':'var(--rd)';
    lines.push('<span style="color:'+rc+';font-weight:600;">'+rating.toFixed(1)+' stars</span> — '+(rating>=4.5?'above the 4.5 threshold':rating>=4.0?'decent but below 4.5':'needs attention — under 4.0 puts people off'));
  }
  if(reply){
    var rm = {always:'replying to all reviews ✓',most:'replying to most — needs to be every one',some:'only some replies — inconsistent, needs fixing',rarely:'not replying — costs ranking and looks bad to new customers'};
    lines.push(rm[reply] || '');
  }
  if(comp && count){
    var d = comp - count;
    if(d > 0) lines.push('<span style="color:var(--rd);font-weight:600;">'+d+' reviews behind top competitor</span> — use this on the call');
    else if(d < 0) lines.push('<span style="color:var(--gr);font-weight:600;">'+Math.abs(d)+' reviews ahead of competitor</span> — worth mentioning');
  }
  if(sum && lines.length){ sum.innerHTML = lines.join('<br>'); sum.style.display = 'block'; }
}

