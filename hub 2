// ── Domain relevance check ──────────────────────────────────────────────────────
function auditDomainCheck(){
  var biz     = (document.getElementById('a-biz').value  || '').toLowerCase().replace(/[^a-z0-9]/g,'');
  var trade   = (document.getElementById('a-trade').value|| '').toLowerCase().replace(/[^a-z0-9]/g,'');
  var loc     = (document.getElementById('a-loc').value  || '').toLowerCase().replace(/[^a-z0-9]/g,'');
  var website = (document.getElementById('a-website').value || '').toLowerCase().replace(/^https?:\/\/(www\.)?/,'').replace(/\/.*/,'');
  var txt     = document.getElementById('ws-domain-text');
  if(!txt) return;
  if(!website || (!biz && !trade)){
    txt.textContent = 'Enter business name and website URL above to check domain relevance.';
    txt.style.color = 'var(--tl)';
    return;
  }
  var domain = website.split('.')[0]; // e.g. "smithplumbing" from "smithplumbing.co.uk"
  var matches = [];
  var concerns = [];
  if(biz   && domain.indexOf(biz.slice(0,5))   > -1) matches.push('business name');
  if(trade && domain.indexOf(trade.slice(0,4))  > -1) matches.push('trade keyword');
  if(loc   && domain.indexOf(loc.slice(0,4))    > -1) matches.push('location');
  var ext = website.split('.').pop();
  var goodExt = ['co.uk','com','uk','net'].indexOf(website.split('.').slice(-2).join('.').replace(/\/.*/,'')) > -1 ||
                ['co','com','uk','net','org'].indexOf(ext) > -1;
  if(!goodExt) concerns.push('unusual TLD (.'+ext+')');
  if(matches.length){
    txt.innerHTML = '&#10003; Good match — domain contains '+matches.join(' and ')+'. <strong>'+website+'</strong>';
    txt.style.color = 'var(--gr)';
  } else {
    txt.innerHTML = '&#9888; Domain <strong>'+website+'</strong> doesn\'t obviously reflect the business name or trade — worth flagging.';
    txt.style.color = 'var(--am)';
    concerns.push('domain doesn\'t match business name or trade');
  }
  if(concerns.length) txt.innerHTML += '<br><span style="color:var(--am);font-size:10px;">Note: '+concerns.join(', ')+'</span>';
  auditState.websiteDomain = website;
}

// ── GMB URL prefill — infer everything possible without fetching ──────────────
function auditGmbPrefill(url){
  var status = document.getElementById('a-gmb-status');
  if(!status) return;
  url = (url||'').trim();
  if(!url||!url.startsWith('http')){ status.textContent=''; return; }

  var isGmb = url.indexOf('google.com/maps')>-1 || url.indexOf('goo.gl/maps')>-1 || url.indexOf('maps.app.goo')>-1;
  if(!isGmb){
    status.innerHTML='&#9888; Doesn\'t look like a Google Maps link — check and re-paste';
    status.style.color='var(--am)'; return;
  }

  // Auto-run immediately on paste
  auditGmbAutoTick(url);
}

function auditGmbAutoTick(urlArg){
  var url = urlArg || (document.getElementById('a-gmb').value||'').trim();
  if(!url) return;

  var ticked=[], manual=[];

  function tick(id,reason){
    var cb=document.getElementById(id);
    if(cb&&!cb.disabled&&!cb.checked){cb.checked=true;auditChk(cb,'gmb');ticked.push(reason);}
    else if(cb&&cb.checked){ticked.push(reason+' (already ✓)');}
  }

  // ── What a valid GMB URL proves ──────────────────────────────────────────
  // If the URL exists and is a real Maps link, the profile is claimed.
  // A full google.com/maps/place URL with data means it's verified —
  // unverified profiles don't show full place pages with this URL format.
  tick('a1','Profile claimed');
  if(url.indexOf('google.com/maps/place')>-1 || url.indexOf('/maps?cid=')>-1){
    tick('a2','Profile verified (full Maps URL confirms this)');
  }

  // ── Parse business name from URL ─────────────────────────────────────────
  var parsedName = '';
  var placeMatch = url.match(/maps\/place\/([^/@?]+)/);
  if(placeMatch){
    parsedName = decodeURIComponent(placeMatch[1].replace(/\+/g,' ')).split('/')[0].trim();
    // Pre-fill business name field if empty
    var bizField = document.getElementById('a-biz');
    if(bizField && !bizField.value && parsedName){
      bizField.value = parsedName;
      auditState.biz = parsedName;
      auditDomainCheck();
    }
  }

  // ── Cross-reference every field the auditor has filled in ────────────────

  // Business name: if field is filled, name is set on the profile
  var bizVal = (document.getElementById('a-biz')||{}).value||'';
  if(bizVal) tick('a2_biz_note'); // not a checkbox but useful
  // We can confirm name is present since we have it
  // a3 = business name is correct (they'd only fill it in if it matched)
  if(bizVal){
    tick('a3','Business name is correct (you verified it to fill this field)');
  }

  // Website: if website field is filled, we know the website is linked on the profile
  var websiteVal = (document.getElementById('a-website')||{}).value||'';
  if(websiteVal){
    tick('a8','Website linked (URL entered above)');
  } else {
    manual.push('Check if a website is linked on the profile');
  }

  // Phone: if the CRM phone field has a number, the number is likely on the profile
  var phoneVal = (document.getElementById('crm-phone')||{}).value||'';
  if(phoneVal){
    tick('a7','Phone number present (from your contact details)');
  } else {
    manual.push('Check the phone number is correct on the profile');
  }

  // Hours: if the auditor filled in the hours note field, hours exist
  var hoursNote = auditState && auditState.gmbNotes4;
  if(hoursNote && hoursNote.trim()){
    tick('a9','Opening hours set (you noted the last post date — hours are visible)');
  } else {
    manual.push('Check opening hours are set and accurate');
  }

  // ── Cross-reference outreach CSV data if a batch is loaded ───────────────
  if(typeof orLeads!=='undefined' && orLeads.length){
    // Try to match current audit business to a loaded lead
    var matchedLead = null;
    var bizLower = bizVal.toLowerCase();
    orLeads.forEach(function(l){
      if(!matchedLead && l.name && bizLower && l.name.toLowerCase().indexOf(bizLower.slice(0,6))>-1){
        matchedLead = l;
      }
      if(!matchedLead && l.gmb && (l.gmb===url||url.indexOf(l.gmb.slice(-20))>-1)){
        matchedLead = l;
      }
    });

    if(matchedLead){
      // We have CSV data for this business — use it
      if(matchedLead.phone){
        var pField=document.getElementById('crm-phone');
        if(pField&&!pField.value) pField.value=matchedLead.phone;
        tick('a7','Phone number present (from your CSV data — '+matchedLead.phone+')');
      }
      if(matchedLead.website){
        var wField=document.getElementById('a-website');
        if(wField&&!wField.value) wField.value=matchedLead.website;
        tick('a8','Website linked (from CSV — '+matchedLead.website.replace(/^https?:\/\//,'').slice(0,30)+')');
        auditDomainCheck();
      }
      if(matchedLead.reviews>0){
        var rcField=document.getElementById('rev-count');
        if(rcField&&!rcField.value){ rcField.value=matchedLead.reviews; auditState.revCount=matchedLead.reviews; }
      }
      if(matchedLead.rating>0){
        var rtField=document.getElementById('rev-rating');
        if(rtField&&!rtField.value){ rtField.value=matchedLead.rating; auditState.revRating=matchedLead.rating; }
      }
      if(matchedLead.reviews>=20) tick('a15_note');
      if(matchedLead.rating>=4.5) tick('a16_note');
      if(matchedLead.reviews){ auditRevScore(); }
      ticked.push('Review data pulled from CSV ('+matchedLead.reviews+' reviews, '+matchedLead.rating+' stars)');
    }
  }

  // ── Photos/logo: can't confirm without seeing the profile ─────────────────
  manual.push('Check logo and cover photo are uploaded');
  manual.push('Check 5+ photos of completed work are there');
  manual.push('Check the description is written and keyword-rich');
  manual.push('Check service area covers the right towns');
  manual.push('Check services are listed with descriptions');
  manual.push('Check the category is the most specific match');

  // ── Update status line ────────────────────────────────────────────────────
  var realTicked = ticked.filter(function(t){ return t.indexOf('_note')===-1; });
  var st=document.getElementById('a-gmb-status');
  if(st){
    var html='<span style="color:var(--gr);font-weight:600;">&#10003; Auto-filled '+realTicked.length+' items</span> ';
    if(realTicked.length) html+='— <span style="font-size:10px;color:var(--tl);">'+realTicked.filter(function(t){return t.indexOf('already')===-1;}).join(' · ')+'</span>';
    html+='<br><span style="font-size:11px;color:var(--tl);"><strong>Still check manually:</strong> '+manual.slice(0,4).join(' · ')+'</span>';
    html+='<br><span style="font-size:11px;color:var(--blue);cursor:pointer;text-decoration:underline;" onclick="window.open(\''+url+'\',\'_blank\')">&#8599; Open profile to verify the rest</span>';
    st.innerHTML=html;
    st.style.color='var(--tx)';
  }

  calcAuditGap();
}



function auditChk(cb,section){
  if(cb.nextElementSibling)cb.nextElementSibling.classList.toggle('ck',cb.checked);
  updateSectionScore(section);
}

function updateSectionScore(section){
  // Website excluded when toggled off
  if(section==='ws' && !auditWebsiteEnabled){
    var el=document.getElementById('ws-score');
    if(el){el.textContent='N/A';el.style.color='var(--tl)';}
    return;
  }
  var keys=Object.keys(auditItems).filter(function(k){return auditItems[k].s===section;});
  var enabled=keys.filter(function(k){
    var cb=document.getElementById(k);
    return cb && !cb.disabled;
  });
  var checked=enabled.filter(function(k){
    var cb=document.getElementById(k);
    return cb && cb.checked;
  });
  var pct=enabled.length>0?Math.round((checked.length/enabled.length)*100):0;
  var scoreId={ws:'ws-score',gmb:'gmb-score',rev:'rev-score'}[section];
  var el=document.getElementById(scoreId);
  if(el){el.textContent=pct+'%';el.style.color=pct>=70?'#22c55e':pct>=40?'#f59e0b':'#ef4444';}
}
function calcAuditGap(){
