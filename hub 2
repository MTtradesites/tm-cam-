function orAutoDetect(lead){
  var auto=[];
  OR_GAPS.forEach(function(g){
    try{if(g.auto(lead))auto.push(g.id);}catch(e){}
  });
  return auto;
}

function orBuildMsg(lead,setterName,tickleIds){
  if(!lead) return '';
  var sel=OR_GAPS.filter(function(g){return tickleIds.indexOf(g.id)>-1;});
  var firstName=lead.name.split(' ')[0];
  var niche=(lead.type||'').toLowerCase();
  var rev=lead.reviews||0;
  var rat=lead.rating?lead.rating.toFixed(1):'';
  var sign=setterName||'[your name]';

  function gapLine(g){
    return (g.msg||g.snippet).replace(/\+0\+/g,rev).replace(/\+r\+/g,rat);
  }

  var obs='';
  if(!sel.length){
    obs='had a look at your google listing and spotted a few things that would get you more calls';
  } else if(sel.length===1){
    obs=gapLine(sel[0]);
  } else {
    obs=gapLine(sel[0])+'. also '+gapLine(sel[1]);
  }

  var offerLine=niche
    ? 'we do free google audits for '+niche+' businesses. 20 minute call, we walk through exactly what we\'d fix to get you more calls.'
    : 'we do free google audits. 20 minute call, we walk through exactly what we\'d fix to get you more calls.';

  if(orTone==='casual'){
    return 'hey '+firstName+','
      +'\n\njust '+obs+'.'
      +'\n\n'+offerLine
      +'\n\nno pitch, no obligation. just a straight look at what we\'d change.'
      +'\n\nworth 20 minutes?'
      +'\n\n'+sign;
  }
  if(orTone==='direct'){
    return firstName+','
      +'\n\n'+obs+'.'
      +'\n\nwe audit google listings for free. 20 minutes, no pitch, just what we\'d fix.'
      +'\n\n20 mins this week?'
      +'\n\n'+sign;
  }
  if(orTone==='curious'){
    return 'hey '+firstName+', quick question about your google listing.'
      +'\n\n'+obs+'.'
      +'\n\nwould it help if we ran through exactly what\'s holding it back? free 20 min audit, no strings attached.'
      +'\n\nlet me know either way.'
      +'\n\n'+sign;
  }
  return '';
}

