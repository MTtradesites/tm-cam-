function orHandleGmbInput(url){
  url=(url||'').trim();
  orCurrentGmb=url;
  var openBtn=document.getElementById('or-gmb-open');
  var hints=document.getElementById('or-gmb-hints');
  if(!openBtn||!hints) return;
  var isValid=url.startsWith('http')&&(url.indexOf('google.com/maps')>-1||url.indexOf('maps.app.goo.gl')>-1||url.indexOf('goo.gl/maps')>-1);
  if(isValid){
    openBtn.style.display='';
    if(orLeads[orIdx]) orLeads[orIdx].gmb=url;
    var lead=orLeads[orIdx];
    var autoFound=lead?lead.auto:[];
    var checkList=[];
