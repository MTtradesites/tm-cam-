function dashUpdateClock(){
  var now=new Date();
  var days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  var h=now.getHours();
  var greeting=h<12?'Good morning':h<17?'Good afternoon':'Good evening';
  var g=document.getElementById('dash-greeting');
  if(g)g.textContent=greeting;
  var d=document.getElementById('dash-date');
  if(d)d.textContent=days[now.getDay()]+', '+now.getDate()+' '+months[now.getMonth()]+' '+now.getFullYear();
  // Days left in month
  var daysInMonth=new Date(now.getFullYear(),now.getMonth()+1,0).getDate();
  var daysLeft=daysInMonth-now.getDate();
  var dl=document.getElementById('dash-days-left');
  if(dl)dl.textContent=daysLeft+' days left this month';
}

