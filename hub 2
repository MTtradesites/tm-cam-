function classifyReply(msg){
  var m=msg.toLowerCase();
  if(/not interested|no thanks|no thank you|don'?t need|don'?t want/.test(m))return'notInterested';
  if(/too expensive|can'?t afford|too much|price|cost/.test(m))return'tooExpensive';
  if(/too busy|no time|flat out|swamped|hectic/.test(m))return'tooBusy';
  if(/think about|get back|let you know|consider/.test(m))return'thinkAboutIt';
  if(/send.*info|email.*info|send.*details|text.*info/.test(m))return'sendInfo';
  if(/already have|got someone|marketing guy|agency/.test(m))return'alreadySomeone';
  if(/word of mouth|enough work|busy enough|plenty of work/.test(m))return'wordOfMouth';
  if(/yes|interested|sounds good|go ahead|let'?s do|book|when|time|availab/.test(m))return'interested';
  if(/reschedule|change.*time|different time|move.*call/.test(m))return'rescheduled';
  if(/cancel|can'?t make|won'?t be|something came up/.test(m))return'cancel';
  if(/not sure|maybe|possibly|might|don'?t know/.test(m))return'notSure';
  if(/tried.*before|didn'?t work|had.*agency|wasted.*money/.test(m))return'triedBefore';
  if(/who are you|who is this|what.*company|how.*get.*number/.test(m))return'whoAreYou';
  return null;
}
