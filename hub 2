    a15:'sfr1',a16:'sfr2',a17:'sfr3',a18:'sfr5'
  };

  var pulled = 0;
  Object.keys(map).forEach(function(auditId){
    var src  = document.getElementById(auditId);
    var dest = document.getElementById(map[auditId]);
    if(!src || !dest) return;
    // Tick sendout box if audit box is UNTICKED (= problem found)
    if(!src.checked){
      dest.checked = true;
      pulled++;
    }
  });

  // Pull review data for the problem statement hint
  var revCount  = document.getElementById('rev-count')  ? document.getElementById('rev-count').value  : '';
  var revComp   = document.getElementById('rev-comp')   ? document.getElementById('rev-comp').value   : '';
  var revRating = document.getElementById('rev-rating') ? document.getElementById('rev-rating').value : '';

  var notice = document.getElementById('so-pull-notice');
  if(notice){
    notice.textContent = pulled > 0
      ? '✓ Pulled ' + pulled + ' findings from the audit — review the ticked items below and add anything else'
      : 'Audit looks clean — no unticked items found. Tick findings manually below.';
    notice.style.display = 'block';
  }

  // Weekly habits — tick the most universally relevant ones
  ['sw1','sw2','sw3','sw4'].forEach(function(id){
    var cb = document.getElementById(id); if(cb) cb.checked = true;
  });

  // Auto-fill problem statement hint from review data
  var prob = document.getElementById('so-problem');
  if(prob && !prob.value && revCount){
    var hint = '';
    if(revCount && parseInt(revCount)<20) hint += parseInt(revCount) + ' Google reviews';
    if(revComp && parseInt(revComp)>parseInt(revCount)) hint += (hint?', ':'')+' competitor has '+revComp;
    if(revRating && parseFloat(revRating)<4.5) hint += (hint?', ':'')+'rating at '+parseFloat(revRating).toFixed(1)+' stars';
    if(hint) prob.placeholder = 'e.g. Their profile has ' + hint + ' — work to do';
  }
}

