function submitDailyLog() {
  var setter = (document.getElementById('dash-log-setter') || {}).value || '';
  var msgs   = parseInt(document.getElementById('dash-log-msgs').value) || 0;
  var replies= parseInt(document.getElementById('dash-log-replies').value) || 0;
  var calls  = parseInt(document.getElementById('dash-log-calls').value) || 0;
  var status = document.getElementById('dash-submit-status');
  var btn    = document.getElementById('dash-submit-btn');

  if (!setter.trim()) {
    if (status) { status.textContent = '⚠ Enter your name first.'; status.style.color = 'var(--am)'; status.style.display = 'block'; }
    return;
  }
  if (!msgs && !replies && !calls) {
    if (status) { status.textContent = '⚠ Fill in at least one number.'; status.style.color = 'var(--am)'; status.style.display = 'block'; }
    return;
  }
  if (!TRACKER_URL || TRACKER_URL === 'PASTE_SETTER_TRACKER_URL_HERE') {
    if (status) { status.textContent = '⚠ Tracker URL not set — see setup instructions.'; status.style.color = 'var(--am)'; status.style.display = 'block'; }
    return;
  }

  var now = new Date();
  var replyRate = msgs > 0 ? Math.round((replies / msgs) * 100) : 0;

  var payload = {
    setter: setter.trim(),
    date: now.toLocaleDateString('en-GB'),
    dayOfWeek: ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][now.getDay()],
    messages: msgs,
    replies: replies,
    auditsBooked: calls,
    replyRate: replyRate
  };

  if (btn) { btn.textContent = 'Submitting...'; btn.style.opacity = '0.6'; btn.disabled = true; }
  if (status) { status.style.display = 'none'; }

  fetch(TRACKER_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain' },
    body: JSON.stringify(payload)
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.ok) {
      if (btn) { btn.innerHTML = '✓ Submitted'; btn.style.opacity = '1'; btn.style.background = 'linear-gradient(135deg,#166534,#22c55e)'; btn.disabled = false; }
      if (status) { status.textContent = 'Logged for ' + setter.trim() + ' — ' + payload.date; status.style.color = 'var(--gr)'; status.style.display = 'block'; }
      setTimeout(function() {
        if (btn) { btn.innerHTML = '&#128203; Submit Today'; btn.style.background = 'linear-gradient(135deg,var(--navy),#1a3a6e)'; }
      }, 3000);
    } else { throw new Error(res.error || 'Unknown error'); }
  })
  .catch(function(err) {
    if (btn) { btn.innerHTML = '✗ Error — try again'; btn.style.opacity = '1'; btn.style.background = 'linear-gradient(135deg,#7f1d1d,#ef4444)'; btn.disabled = false; }
    if (status) { status.textContent = err.toString().substring(0, 80); status.style.color = 'var(--rd)'; status.style.display = 'block'; }
    setTimeout(function() {
      if (btn) { btn.innerHTML = '&#128203; Submit Today'; btn.style.background = 'linear-gradient(135deg,var(--navy),#1a3a6e)'; }
    }, 4000);
  });
}

