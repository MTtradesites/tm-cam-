var rcLayout='authority', rcColour='#0a1628', rcLogoURL=null, rcCurrentStep=1;
var rcLayouts=['authority','split','bold'];

function rcGoStep(n){
  rcCurrentStep=n;
  document.querySelectorAll('.rc-flow-step').forEach((s,i)=>{
    s.classList.remove('active','done');
    if(i+1===n)s.classList.add('active');
    else if(i+1<n)s.classList.add('done');
    var num=document.getElementById('rcfn-'+(i+1));
    if(num){
      if(i+1<n){num.textContent='✓';num.style.background='var(--gr)';}
      else if(i+1===n){num.textContent=i+1;num.style.background='var(--blue)';}
      else{num.textContent=i+1;num.style.background='var(--gm)';}
    }
  });
  document.querySelectorAll('.rc-step-panel').forEach(p=>p.classList.remove('active'));
  var panel=document.getElementById('rcsp-'+n);
  if(panel)panel.classList.add('active');
  var label=document.getElementById('rc-step-label');
  if(label)label.textContent='Step '+n+' of 4';
}

function rcSetLayout(l,btn){
  rcLayout=l;
  document.querySelectorAll('.rc-lay-btn').forEach(b=>{b.classList.remove('on');});
  if(btn)btn.classList.add('on');
  rcLayouts.forEach(n=>{
    var el=document.getElementById('rcout-'+n);
    if(el)el.style.display=(n===l)?'flex':'none';
  });
  rcUpdate();
}

function rcSetCol(col,btn){
  rcColour=col;
  document.querySelectorAll('.rc-col-swatch').forEach(s=>s.classList.remove('on'));
  if(btn)btn.classList.add('on');
  var cp=document.getElementById('rc-col-pick');var hx=document.getElementById('rc-hex');
  if(cp&&/^#[0-9a-fA-F]{6}$/.test(col))cp.value=col;
  if(hx)hx.value=col;
  rcUpdate();
}

function rcSyncColPick(){
  var v=document.getElementById('rc-col-pick').value;
  document.getElementById('rc-hex').value=v;
  rcColour=v;
  document.querySelectorAll('.rc-col-swatch').forEach(s=>s.classList.remove('on'));
  rcUpdate();
}

function rcSyncHex(){
  var v=document.getElementById('rc-hex').value;
  if(/^#[0-9a-fA-F]{6}$/.test(v)){
    document.getElementById('rc-col-pick').value=v;
    rcColour=v;
    document.querySelectorAll('.rc-col-swatch').forEach(s=>s.classList.remove('on'));
    rcUpdate();
  }
}

function rcLoadLogo(){
  var f=document.getElementById('rc-logo').files[0];
  if(!f)return;
  var reader=new FileReader();
  reader.onload=function(e){
    rcLogoURL=e.target.result;
    document.getElementById('rc-logo-ph').style.display='none';
    var prev=document.getElementById('rc-logo-prev');
    prev.src=e.target.result;prev.style.display='block';
    var drop=document.getElementById('rc-logo-drop');
    if(drop){drop.style.borderColor='var(--blue)';drop.style.background='var(--bp)';}
    rcUpdate();
    // Extract colours from logo
    var img=new Image();img.crossOrigin='anonymous';
    img.onload=function(){
      extractColors(img,function(colors){
        var row=document.getElementById('rc-swatch-row');
        var wrap=document.getElementById('rc-swatches');
        if(row&&colors.length){
          row.innerHTML='';
          colors.forEach(function(col,i){
            var sw=document.createElement('div');
            sw.className='rc-col-swatch';
            sw.style.cssText='width:26px;height:26px;border-radius:50%;background:'+col+';cursor:pointer;border:3px solid transparent;transition:all .15s;';
            if(i===0){sw.style.borderColor='var(--blue)';rcColour=col;rcUpdate();}
            sw.title=col;
            sw.onclick=function(){
              document.querySelectorAll('.rc-col-swatch').forEach(s=>s.style.borderColor='transparent');
              this.style.borderColor='var(--blue)';
              rcColour=col;
              var cp=document.getElementById('rc-col-pick');var hx=document.getElementById('rc-hex');
              if(cp)cp.value=col;if(hx)hx.value=col;
              rcUpdate();
            };
            row.appendChild(sw);
          });
          if(wrap)wrap.style.display='block';
        }
      });
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(f);
}

function rcUpdate(){
  var biz=(document.getElementById('rc-biz').value)||'Business Name';
  var trade=(document.getElementById('rc-trade').value)||'Trade';
  var offer=(document.getElementById('rc-offer')||{value:''}).value||'';
  var col=rcColour;

  // Update all layouts
  rcLayouts.forEach(function(l){
    var b=document.getElementById('rcb-'+l);
    var t=document.getElementById('rctr-'+l);
    var top=document.getElementById('rct-'+l);
    var ob=document.getElementById('rco-'+l);
    if(b)b.textContent=biz;
    if(t)t.textContent=trade;
    if(top)top.style.background=col;
    if(ob){
      ob.style.display=offer?'block':'none';
      if(offer)ob.innerHTML='🎁 '+offer;
      // colour the offer box
      ob.style.background='rgba(245,158,11,.15)';
      ob.style.border='1px solid rgba(245,158,11,.4)';
      ob.style.color='#fcd34d';
    }
    // Accent stripe for authority
    if(l==='authority'){
      var stripe=top?top.querySelector('div[style*="height:3px"]'):null;
    }
    // Logo
    var lg=document.getElementById('rcl-'+l);
    if(lg&&rcLogoURL){
      lg.innerHTML='<img src="'+rcLogoURL+'" style="width:85%;height:85%;object-fit:contain;border-radius:4px;">';
    }
  });
}

function rcUpdateQR(){
  rcUpdate();
  var link=(document.getElementById('rc-link').value||'').trim();
  var hint=document.getElementById('rc-qr-hint');
  var status=document.getElementById('rc-link-status');
  if(!link||!link.startsWith('http')){
    if(hint)hint.style.display='block';
    if(status)status.textContent='';
    return;
  }
  if(hint)hint.style.display='none';
  if(status)status.innerHTML='<span style="color:var(--gr);font-weight:700;">✓ Link valid — QR generating...</span>';
  rcLayouts.forEach(function(l){
    var container=document.getElementById('qr-'+l);
    if(!container)return;
    container.innerHTML='';
    try{
      var sz=(l==='split')?90:110;
      new QRCode(container,{text:link,width:sz,height:sz,colorDark:rcColour,colorLight:'#ffffff',correctLevel:QRCode.CorrectLevel.H});
      setTimeout(function(){if(status)status.innerHTML='<span style="color:var(--gr);font-weight:700;">✓ QR code ready</span>';},300);
    }catch(e){container.innerHTML='<span style="font-size:10px;color:var(--tl);">QR error</span>';}
  });
}

