    var allHints=checkList.concat(manual).slice(0,5);
    hints.innerHTML='<strong style="color:var(--navy);">Profile open. Check these:</strong><br>'+allHints.map(function(h){return '\u2022 '+h;}).join('<br>');
    hints.style.display='block';
