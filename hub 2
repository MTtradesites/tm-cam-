function pfRR(ctx,x,y,w,h,r){
  ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);
  ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);
  ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);
  ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);
  ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();ctx.fill();
}

function pfWrap(ctx,text,maxW,maxLines){
  var words=(text||'').split(' '),lines=[],cur='';
  for(var i=0;i<words.length;i++){
    var test=cur?(cur+' '+words[i]):words[i];
    if(ctx.measureText(test).width>maxW&&cur){
      lines.push(cur);
      if(lines.length>=maxLines){
        var rest=words.slice(i).join(' ');
        while(rest&&ctx.measureText(lines[lines.length-1]+' '+rest+'...').width>maxW)rest=rest.substring(0,rest.lastIndexOf(' '));
        lines[lines.length-1]+=(rest?' '+rest:'')+'...';
        return lines;
      }
      cur=words[i];
    } else cur=test;
  }
  if(cur)lines.push(cur);
  return lines;
}

function pfBullets(body,max){
  if(!body)return[];
  var raw=body.replace(/\\n/g,'\n').split('\n').map(s=>s.trim()).filter(Boolean);
  if(raw.length<=1){
    var s=raw[0]||'';
    var nb=s.split(/\d+\.\s+/).map(x=>x.trim()).filter(Boolean);
    if(nb.length>1){raw=nb;}
    else{var ss=s.split(/\.\s+/).map(x=>x.trim()).filter(Boolean);raw=ss.length>1?ss:[s];}
  }
  return raw.slice(0,max).map(s=>s.replace(/^[\d\-*]+[.):\s]+/,'').trim().substring(0,92));
}

