function orUpdateBadge(status){
  var b=document.getElementById('or-status-badge'); if(!b)return;
  var map={pending:'or-badge-pending',sent:'or-badge-sent',skipped:'or-badge-skipped',not_interested:'or-badge-no',follow_up:'or-badge-follow_up'};
  var lbl={pending:'Pending',sent:'Sent \u2713',skipped:'Skipped',not_interested:'Not interested',follow_up:'Follow up'};
  b.className='or-badge '+(map[status]||'or-badge-pending');
  b.textContent=lbl[status]||status;
}

function orUpdateProgress(){
  var total=orLeads.length;
  var sent=orLeads.filter(function(l){return l.status==='sent';}).length;
  var skipped=orLeads.filter(function(l){return l.status==='skipped';}).length;
  var notInt=orLeads.filter(function(l){return l.status==='not_interested';}).length;
  var followUp=orLeads.filter(function(l){return l.status==='follow_up';}).length;
  var pending=total-sent-skipped-notInt-followUp;
