  el.innerHTML='Gap: <strong style="color:var(--rd);">'+gap+' reviews</strong> · At 2/week: ~'+Math.ceil(gap/2)+' weeks. At 4/week with review card: ~'+Math.ceil(gap/4)+' weeks.';
