    dz.addEventListener('dragover',function(e){e.preventDefault();dz.classList.add('drag');});
    dz.addEventListener('dragleave',function(){dz.classList.remove('drag');});
    dz.addEventListener('drop',function(e){e.preventDefault();dz.classList.remove('drag');if(e.dataTransfer.files[0])pfHandleCSV(e.dataTransfer.files[0]);});
  }
});

function pfHandleCSV(file){
  var r=new FileReader();
  r.onload=function(e){pfParseCSV(e.target.result);};
  r.readAsText(file);
}

function pfParseCSV(txt){
  var lines=txt.split('\n').filter(l=>l.trim());
  if(!lines.length)return;
  var hdrs=pfSplitLine(lines[0]);
  var hi=-1,bi=-1,ci=-1;
  hdrs.forEach(function(h,i){
    var hl=h.toLowerCase().replace(/[^a-z]/g,'');
    if(hl==='headline')hi=i;
    if(hl==='bodytext'||hl==='body')bi=i;
    if(hl==='category')ci=i;
  });
  if(hi<0){alert('No Headline column found. Check your CSV headers.');return;}
  if(bi<0){alert('No Body_Text column found. Check your CSV headers.');return;}
  pfPosts=[];
  for(var i=1;i<lines.length;i++){
    var v=pfSplitLine(lines[i]);
    if(!v[hi]||!v[hi].trim())continue;
    pfPosts.push({head:v[hi].trim(),body:v[bi]?v[bi].trim():'',cat:ci>=0&&v[ci]?v[ci].trim():''});
  }
  var st=document.getElementById('pf-csv-status');
  if(st)st.innerHTML='<span style="color:#22c55e;font-weight:700;font-size:13px;">✓ '+pfPosts.length+' posts loaded</span>';
  var btn=document.getElementById('pf-gen-btn');
  if(btn){btn.disabled=false;btn.textContent='Generate '+pfPosts.length+' Posts ⚡';}
  var drop=document.getElementById('pf-drop');
  if(drop){drop.style.borderColor='var(--gr)';drop.style.background='#f0fdf4';}
}

function pfSplitLine(line){
  var res=[],cur='',q=false;
  for(var i=0;i<line.length;i++){
    var ch=line[i];
    if(ch==='"'){q=!q;}
    else if(ch===','&&!q){res.push(cur.trim());cur='';}
    else{cur+=ch;}
  }
  res.push(cur.trim());
  return res;
}

function pfLoadLogo(inp){
  var f=inp.files[0];if(!f)return;
  var r=new FileReader();
  r.onload=function(e){
    var img=new Image();
    img.onload=function(){
      pfLogo=img;
      document.getElementById('pf-logo-ph').style.display='none';
      var prev=document.getElementById('pf-logo-prev');
      prev.src=e.target.result;prev.style.display='block';
      extractColors(img,function(colors){
        var swRow=document.getElementById('pf-swatch-row');
        var swWrap=document.getElementById('pf-swatches');
        if(swRow&&colors.length){
          swRow.innerHTML='';
          colors.forEach(function(col,idx){
            var sw=document.createElement('div');
            sw.style.cssText='width:26px;height:26px;border-radius:50%;background:'+col+';cursor:pointer;border:3px solid '+(idx===0?'var(--blue)':'transparent')+';flex-shrink:0;transition:all .15s;';
            sw.title=col;
            (function(c){sw.onclick=function(){
              document.querySelectorAll('#pf-swatch-row div').forEach(s=>s.style.borderColor='transparent');
              this.style.borderColor='var(--blue)';
              pfApplyLogoColour(c);
            };})(col);
            swRow.appendChild(sw);
          });
          if(swWrap)swWrap.style.display='block';
          if(colors[0])pfApplyLogoColour(colors[0]);
        }
      });
    };
    img.src=e.target.result;
  };
  r.readAsDataURL(f);
}

function pfAddPhotos(inp){
  var files=Array.from(inp.files);
  var remaining=20-pfPhotos.length;
  if(remaining<=0){pfRenderPhotoBank();inp.value='';return;}
  files.slice(0,remaining).forEach(function(f){
    var r=new FileReader();
    r.onload=function(e){
      var img=new Image();
      img.onload=function(){
        pfPhotos.push(img);
        pfRenderPhotoBank();
      };
      img.src=e.target.result;
    };
    r.readAsDataURL(f);
  });
  inp.value='';
}

function pfRenderPhotoBank(){
  var bank=document.getElementById('pf-imgbank');
  if(!bank)return;
  bank.innerHTML='';
  var countEl=document.getElementById('pf-photo-count');
  var warnEl=document.getElementById('pf-photo-warning');
  if(countEl)countEl.textContent=pfPhotos.length+' / 20';
  if(warnEl)warnEl.style.display=pfPhotos.length>=20?'block':'none';
  pfPhotos.forEach(function(img,idx){
    var wrap=document.createElement('div');
    wrap.style.cssText='aspect-ratio:1;border-radius:6px;overflow:hidden;cursor:pointer;border:2px solid '+(idx===pfActivePhoto?'var(--blue)':'transparent')+';transition:all .15s;position:relative;flex-shrink:0;';
    var i=document.createElement('img');
    i.src=img.src;i.style.cssText='width:100%;height:100%;object-fit:cover;display:block;';
    var del=document.createElement('div');
    del.style.cssText='position:absolute;top:2px;right:2px;width:16px;height:16px;background:rgba(239,68,68,.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;font-weight:700;cursor:pointer;line-height:1;';
    del.innerHTML='×';
    del.onclick=function(e){e.stopPropagation();pfPhotos.splice(idx,1);if(pfActivePhoto>=pfPhotos.length)pfActivePhoto=Math.max(0,pfPhotos.length-1);pfRenderPhotoBank();};
    if(idx===pfActivePhoto){
      var badge=document.createElement('div');
      badge.style.cssText='position:absolute;bottom:2px;left:2px;background:var(--blue);border-radius:3px;padding:1px 4px;font-size:8px;font-weight:700;color:#fff;font-family:var(--fh);';
      badge.textContent='PRIMARY';
      wrap.appendChild(badge);
    }
    wrap.appendChild(i);wrap.appendChild(del);
    wrap.onclick=function(){pfActivePhoto=idx;pfRenderPhotoBank();};
    bank.appendChild(wrap);
  });
  // Add button — only if under limit
  if(pfPhotos.length<20){
    var add=document.createElement('div');
    add.style.cssText='aspect-ratio:1;border-radius:6px;border:2px dashed var(--gm);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;gap:1px;background:#fff;transition:all .15s;';
    add.innerHTML='<div style="font-size:18px;color:var(--gm);">+</div><div style="font-size:8px;color:var(--tl);font-weight:600;font-family:var(--fh);">Add</div>';
    add.onclick=function(){document.getElementById('pf-photo-input').click();};
    bank.appendChild(add);
  }
}

function pfApplyLogoColour(col){
  if(window.PF_THEMES&&window.pfStyle){
    var t=window.PF_THEMES[window.pfStyle];
    if(t){t.acc=col;t.cat=col;}
  }
}

function pfPickStyle(s,btn){
  pfStyle=window.pfStyle=s;
  document.querySelectorAll('.pf-pick-btn[id^="pfstyle-"]').forEach(b=>{b.classList.remove('on');b.style.borderColor='var(--gm)';});
  if(btn){btn.classList.add('on');btn.style.borderColor='var(--blue)';}
  if(pfPosts.length&&Object.keys(pfCanvases).length)pfGenerate();
}

function pfPickLayout(l,btn){
  pfLayout=window.pfLayout=l;
  document.querySelectorAll('.pf-pick-btn[id^="pflayout-"]').forEach(b=>{b.classList.remove('on');b.style.borderColor='var(--gm)';});
  if(btn){btn.classList.add('on');btn.style.borderColor='var(--blue)';}
  if(pfPosts.length&&Object.keys(pfCanvases).length)pfGenerate();
}

function pfGenerate(){
  if(!pfPosts.length)return;
  var gal=document.getElementById('pf-gal');
  if(gal)gal.innerHTML='';
  pfCanvases={};
  var biz=document.getElementById('pf-biz').value.trim();
  var web=document.getElementById('pf-web').value.trim();
  var empty=document.getElementById('pf-empty');
  if(gal)gal.style.display='grid';
  if(empty)empty.style.display='none';
  var title=document.getElementById('pf-gal-title');
  if(title)title.textContent=pfPosts.length+' Posts — '+pfStyle.charAt(0).toUpperCase()+pfStyle.slice(1)+' / '+pfLayout.charAt(0).toUpperCase()+pfLayout.slice(1);
  var badge=document.getElementById('pf-count-badge');
  if(badge){badge.textContent=pfPosts.length+' posts';badge.style.display='inline-block';}
  var bar=document.getElementById('pf-bar');if(bar)bar.style.width='0%';
  var btn=document.getElementById('pf-gen-btn');
  if(btn){btn.disabled=true;btn.textContent='Generating...';}
  var i=0;
  function next(){
    if(i>=pfPosts.length){
      if(bar)bar.style.width='100%';
      if(btn){btn.disabled=false;btn.textContent='Regenerate All ⚡';}
      var st=document.getElementById('pf-status');if(st)st.textContent=pfPosts.length+' posts ready';
      return;
    }
    var p=pfPosts[i],idx=i;
    var card=document.createElement('div');card.className='pf-gal-card';
    var cv=document.createElement('canvas');cv.width=1080;cv.height=1080;
    cv.style.cssText='width:100%;aspect-ratio:1;display:block;';cv.id='pfcv-'+idx;
    var foot=document.createElement('div');foot.className='pf-gal-foot';
    foot.innerHTML=(p.cat?'<div class="pf-gal-cat">'+p.cat+'</div>':'')+
      '<div class="pf-gal-head">'+p.head+'</div>'+
      '<button class="pf-dl-one" onclick="pfDlOne('+idx+')">⬇ Download</button>';
    card.appendChild(cv);card.appendChild(foot);gal.appendChild(card);
    // Choose photo for this post
    var photo=pfPhotos.length?pfPhotos[idx%pfPhotos.length]:null;
    pfDrawPost(cv,p,biz,web,pfStyle,pfLogo,pfLayout,photo);
    pfCanvases[idx]=cv;
    if(bar)bar.style.width=(((idx+1)/pfPosts.length)*100)+'%';
    var st=document.getElementById('pf-status');if(st)st.textContent=(idx+1)+' / '+pfPosts.length;
    i++;setTimeout(next,0);
  }
  next();
}

// ── POST THEMES ──────────────────────────────────────────
var PF_THEMES=window.PF_THEMES={
  dark: {bg0:'#0a1628',bg1:'#111f38',head:'#ffffff',body:'rgba(255,255,255,0.82)',cat:'#45b3f5',catbg:'rgba(45,155,218,0.15)',div:'rgba(255,255,255,0.12)',foot:'rgba(255,255,255,0.32)',acc:'#2d9bda',logobg:'rgba(255,255,255,0.07)'},
  light:{bg0:'#ffffff',bg1:'#f5f8fc',head:'#0a1628',body:'#374a60',cat:'#2d9bda',catbg:'#dceefa',div:'#dce6f0',foot:'#8090a0',acc:'#2d9bda',logobg:'#edf2f7'},
  blue: {bg0:'#1565a0',bg1:'#0d4070',head:'#ffffff',body:'rgba(255,255,255,0.88)',cat:'#ffffff',catbg:'rgba(255,255,255,0.20)',div:'rgba(255,255,255,0.18)',foot:'rgba(255,255,255,0.45)',acc:'#ffffff',logobg:'rgba(255,255,255,0.15)'},
  amber:{bg0:'#111f38',bg1:'#0a1628',head:'#ffffff',body:'rgba(255,255,255,0.80)',cat:'#f59e0b',catbg:'rgba(245,158,11,0.14)',div:'rgba(255,255,255,0.10)',foot:'rgba(255,255,255,0.28)',acc:'#f59e0b',logobg:'rgba(255,255,255,0.06)'}
};

// ── DRAW ENGINE ─────────────────────────────────────────
function pfDrawPost(canvas,post,biz,web,sty,logo,layout,photo){
  layout=layout||'standard';
  var ctx=canvas.getContext('2d');
  var T=PF_THEMES[sty]||PF_THEMES.dark;
  var W=1080,H=1080,PAD=72;

  // ── PHOTO BACKGROUND LAYOUT ──
  if(layout==='photo'&&photo){
    // Full bleed photo with gradient overlay
    var pAR=photo.width/photo.height;
    var dw=W,dh=W/pAR;
    if(dh<H){dh=H;dw=H*pAR;}
    ctx.drawImage(photo,(W-dw)/2,(H-dh)/2,dw,dh);
    // Dark overlay gradient from bottom
    var grad=ctx.createLinearGradient(0,0,0,H);
    grad.addColorStop(0,'rgba(0,0,0,0.3)');
    grad.addColorStop(0.4,'rgba(0,0,0,0.2)');
    grad.addColorStop(0.65,'rgba(0,0,0,0.65)');
    grad.addColorStop(1,'rgba(0,0,0,0.88)');
    ctx.fillStyle=grad;ctx.fillRect(0,0,W,H);
    // Brand accent bar top
    ctx.fillStyle=T.acc;ctx.globalAlpha=0.85;ctx.fillRect(0,0,W,8);ctx.globalAlpha=1;
    // Logo top-right
    if(logo){
      var mLW=200,mLH=72,la=logo.width/logo.height,lw,lh;
      if(la>mLW/mLH){lw=mLW;lh=lw/la;}else{lh=mLH;lw=lh*la;}
      ctx.fillStyle='rgba(0,0,0,0.35)';pfRR(ctx,W-PAD-lw-12,38,lw+24,mLH+12,10);
      ctx.drawImage(logo,W-PAD-lw,44+(mLH-lh)/2,lw,lh);
    } else if(biz){
      ctx.fillStyle='#fff';ctx.font='700 40px Syne, sans-serif';
      ctx.textAlign='right';ctx.textBaseline='middle';ctx.fillText(biz.substring(0,26),W-PAD,80);ctx.textAlign='left';
    }
    // Category pill top-left
    if(post.cat){
      ctx.fillStyle=T.acc;ctx.globalAlpha=0.9;
      var catW=ctx.measureText(post.cat.toUpperCase()).width;ctx.font='700 24px DM Sans, sans-serif';
      catW=ctx.measureText(post.cat.toUpperCase()).width+40;
      pfRR(ctx,PAD,44,catW,42,21);ctx.globalAlpha=1;
      ctx.fillStyle='#fff';ctx.font='700 22px DM Sans, sans-serif';
      ctx.textAlign='left';ctx.textBaseline='middle';
      ctx.fillText(post.cat.toUpperCase(),PAD+20,65);
    }
    // Headline — lower third
    ctx.fillStyle='#ffffff';ctx.textAlign='left';ctx.textBaseline='top';
    var headText=post.head||'';var hSize=76;
    while(hSize>44){ctx.font='800 '+hSize+'px Syne, sans-serif';var hL=pfWrap(ctx,headText,W-PAD*2,2);if(hL.length<=2)break;hSize-=4;}
    ctx.font='800 '+hSize+'px Syne, sans-serif';
    var hLines=pfWrap(ctx,headText,W-PAD*2,2);
    var hTop=H-380;
    hLines.forEach(function(ln,i){ctx.fillText(ln,PAD,hTop+i*(hSize+12));});
    // Accent line
    ctx.fillStyle=T.acc;ctx.fillRect(PAD,hTop+hLines.length*(hSize+12)+10,80,4);
    // Bullets
    var bullets=pfBullets(post.body,3);
    ctx.font='34px DM Sans, sans-serif';ctx.fillStyle='rgba(255,255,255,0.85)';
    var bY=hTop+hLines.length*(hSize+12)+40;
    bullets.forEach(function(b,i){
      ctx.fillStyle=T.acc;ctx.beginPath();ctx.arc(PAD+9,bY+i*68+18,6,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='rgba(255,255,255,0.85)';
      var bl=pfWrap(ctx,b,W-PAD*2-30,1);
      ctx.fillText(bl[0]||b,PAD+26,bY+i*68);
    });
    // Footer
    ctx.fillStyle='rgba(255,255,255,0.35)';ctx.font='500 22px DM Sans, sans-serif';
    ctx.textAlign='left';ctx.textBaseline='middle';
    var ft=biz||'';if(web)ft+=(ft?' · ':'')+web;
    ctx.fillText(ft.substring(0,52),PAD,H-36);
    return;
  }

  // For photo layout without photos — fall to standard
  if(layout==='photo'){layout='standard';}
  // Dispatch split and horizon
  if(layout==='split'){pfDrawSplit(canvas,post,biz,web,sty,logo,photo);return;}
  if(layout==='horizon'){pfDrawHorizon(canvas,post,biz,web,sty,logo,photo);return;}

  // ── CENTRED LAYOUT ──
  if(layout==='centered'){
    var g=ctx.createRadialGradient(W/2,360,80,W/2,H/2,680);g.addColorStop(0,T.bg1);g.addColorStop(1,T.bg0);
    ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
    // Ring decoration
    ctx.strokeStyle=T.acc;ctx.globalAlpha=0.07;ctx.lineWidth=100;
    ctx.beginPath();ctx.arc(W/2,H/2,460,0,Math.PI*2);ctx.stroke();ctx.globalAlpha=1;
    // Logo centred
    if(logo){
      var mLW=200,mLH=80,la=logo.width/logo.height,lw,lh;
      if(la>mLW/mLH){lw=mLW;lh=lw/la;}else{lh=mLH;lw=lh*la;}
      ctx.fillStyle=T.logobg;pfRR(ctx,W/2-lw/2-14,58,lw+28,mLH+18,12);
      ctx.drawImage(logo,W/2-lw/2,64+(mLH-lh)/2,lw,lh);
    } else if(biz){
      ctx.fillStyle=T.head;ctx.font='700 44px Syne, sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(biz.substring(0,26),W/2,108);
    }
    // Rule
    ctx.strokeStyle=T.div;ctx.lineWidth=1;ctx.globalAlpha=0.5;
    ctx.beginPath();ctx.moveTo(PAD*2,210);ctx.lineTo(W-PAD*2,210);ctx.stroke();ctx.globalAlpha=1;
    // Category
    if(post.cat){
      ctx.fillStyle=T.catbg;pfRR(ctx,W/2-80,226,160,38,19);
      ctx.fillStyle=T.cat;ctx.font='700 21px DM Sans, sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(post.cat.toUpperCase(),W/2,245);
    }
    // Headline centred
    ctx.fillStyle=T.head;ctx.textAlign='center';ctx.textBaseline='top';
    var headText=post.head||'';var hSize=82;
    while(hSize>46){ctx.font='800 '+hSize+'px Syne, sans-serif';var hL=pfWrap(ctx,headText,W-PAD*2.5,2);if(hL.length<=2)break;hSize-=4;}
    ctx.font='800 '+hSize+'px Syne, sans-serif';
    var hLines=pfWrap(ctx,headText,W-PAD*2.5,2);
    var hTop=post.cat?290:250;
    hLines.forEach(function(ln,i){ctx.fillText(ln,W/2,hTop+i*(hSize+14));});
    ctx.fillStyle=T.acc;ctx.fillRect(W/2-48,hTop+hLines.length*(hSize+14)+10,96,4);
    // Bullets as rounded pill rows
    var bullets=pfBullets(post.body,3);
    ctx.font='34px DM Sans, sans-serif';
    var bY=hTop+hLines.length*(hSize+14)+44;
    bullets.forEach(function(b,i){
      var by=bY+i*102;
      ctx.fillStyle=T.catbg;pfRR(ctx,PAD,by,W-PAD*2,74,8);
      ctx.fillStyle=T.body;ctx.textAlign='center';ctx.textBaseline='middle';
      var wrapped=pfWrap(ctx,b,W-PAD*2-40,1);
      ctx.fillText(wrapped[0]||b,W/2,by+37);
    });
    // Footer
    ctx.strokeStyle=T.div;ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(PAD,920);ctx.lineTo(W-PAD,920);ctx.stroke();
    var ft=biz||'';if(web)ft+=(ft?' · ':'')+web;
    ctx.fillStyle=T.foot;ctx.font='500 22px DM Sans, sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(ft.substring(0,52),W/2,968);
    return;
  }

  // ── MINIMAL LAYOUT ──
  if(layout==='minimal'){
    ctx.fillStyle=T.bg0;ctx.fillRect(0,0,W,H);
    ctx.fillStyle=T.acc;ctx.fillRect(0,0,W,7);
    // Logo top-left small
    if(logo){
      var mLW=150,mLH=58,la=logo.width/logo.height,lw,lh;
      if(la>mLW/mLH){lw=mLW;lh=lw/la;}else{lh=mLH;lw=lh*la;}
      ctx.drawImage(logo,PAD,54+(mLH-lh)/2,lw,lh);
    } else if(biz){
      ctx.fillStyle=T.acc;ctx.font='700 36px Syne, sans-serif';ctx.textAlign='left';ctx.textBaseline='middle';
      ctx.fillText(biz.substring(0,26),PAD,84);
    }
    // Large headline
    ctx.fillStyle=T.head;ctx.textAlign='left';ctx.textBaseline='top';
    var headText=post.head||'';var hSize=96;
    while(hSize>52){ctx.font='800 '+hSize+'px Syne, sans-serif';var hL=pfWrap(ctx,headText,W-PAD*2,2);if(hL.length<=2)break;hSize-=4;}
    ctx.font='800 '+hSize+'px Syne, sans-serif';
    var hLines=pfWrap(ctx,headText,W-PAD*2,2);
    hLines.forEach(function(ln,i){ctx.fillText(ln,PAD,188+i*(hSize+16));});
    // Accent dash
    var divY=188+hLines.length*(hSize+16)+24;
    ctx.fillStyle=T.acc;ctx.fillRect(PAD,divY,52,4);
    // Clean bullet list
    var bullets=pfBullets(post.body,4);
    ctx.font='38px DM Sans, sans-serif';
    var bY=divY+44;
    bullets.forEach(function(b,i){
      var by=bY+i*100;
      ctx.fillStyle=T.acc;ctx.fillRect(PAD,by+12,4,42);
      ctx.fillStyle=T.body;
      var wrapped=pfWrap(ctx,b,W-PAD*2-22,2);
      wrapped.forEach(function(ln,j){ctx.fillText(ln,PAD+20,by+j*46);});
    });
    // Footer minimal
    var ft=biz||'';if(web)ft+=(ft?'  /  ':'')+web;
    ctx.fillStyle=T.foot;ctx.font='500 21px DM Sans, sans-serif';ctx.textAlign='left';ctx.textBaseline='middle';
    ctx.fillText(ft.substring(0,52),PAD,H-38);
    return;
  }

  // ── STANDARD LAYOUT (default) ──
  var g=ctx.createLinearGradient(0,0,0,H);g.addColorStop(0,T.bg0);g.addColorStop(1,T.bg1);
  ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
  // Left accent stripe
  ctx.fillStyle=T.acc;ctx.globalAlpha=0.7;ctx.fillRect(0,0,8,H);ctx.globalAlpha=1;
  // Logo
  if(logo){
    var mLW=240,mLH=86,la=logo.width/logo.height,lw,lh;
    if(la>mLW/mLH){lw=mLW;lh=lw/la;}else{lh=mLH;lw=lh*la;}
    ctx.fillStyle=T.logobg;pfRR(ctx,PAD-10,44,lw+28,mLH+12,10);
    ctx.drawImage(logo,PAD,50+(mLH-lh)/2,lw,lh);
  } else if(biz){
    ctx.fillStyle=T.head;ctx.font='800 48px Syne, sans-serif';ctx.textAlign='left';ctx.textBaseline='middle';
    ctx.fillText(biz.substring(0,26),PAD,100);
    ctx.fillStyle=T.acc;ctx.fillRect(PAD,126,Math.min(ctx.measureText(biz.substring(0,26)).width,380),4);
  }
  // Category badge
  if(post.cat){
    var cw=ctx.measureText(post.cat.toUpperCase()).width;ctx.font='700 26px DM Sans, sans-serif';cw=ctx.measureText(post.cat.toUpperCase()).width+44;
    ctx.fillStyle=T.catbg;pfRR(ctx,PAD,162,cw,44,22);
    ctx.fillStyle=T.cat;ctx.font='700 24px DM Sans, sans-serif';ctx.textAlign='left';ctx.textBaseline='middle';
    ctx.fillText(post.cat.toUpperCase(),PAD+22,184);
  }
  // Rule
