// ── GOAL ──────────────────────────────────────────────
function dashUpdateGoal(){
  var goal=parseInt(document.getElementById('dash-goal-input').value)||2;
  var closes=parseInt(document.getElementById('dash-closes-input').value)||0;
  var pct=goal>0?Math.min(Math.round(closes/goal*100),100):0;
  var bar=document.getElementById('dash-goal-bar');
  if(bar)bar.style.width=pct+'%';
  var pctEl=document.getElementById('dash-goal-pct');
  if(pctEl)pctEl.textContent=pct+'%';
  var tBar=document.getElementById('dash-target-bar');
  if(tBar)tBar.style.width=pct+'%';
  var tProg=document.getElementById('dash-target-progress');
  if(tProg)tProg.textContent=closes;
  var tGoal=document.getElementById('dash-target-goal');
  if(tGoal)tGoal.textContent=goal;
  var msg=document.getElementById('dash-goal-msg');
  if(msg){
    var left=goal-closes;
    if(left<=0)msg.innerHTML='<span style="color:var(--gr);">🎉 Target smashed</span>';
    else if(pct>=50)msg.innerHTML='<span style="color:var(--am);">'+left+' more to hit target</span>';
    else msg.innerHTML='<span style="color:var(--tl);">'+left+' closes to go</span>';
  }
  dashSaveState();
}

