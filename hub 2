  if(phone) email += ' on ' + phone;
  email += ' — I\'m usually quick to respond.\n\n';
  email += 'Looking forward to getting this moving for you.\n\n';
  email += sender + '\nMT Trade Sites';

  document.getElementById('ob-email-text').textContent = email;
  document.getElementById('ob-output').style.display = 'block';
  // Show correct Tally link
  var tallyLinks = {
    t1: { url: 'https://tally.so/r/3XVdEP', label: 'Tier 1 — Found · GMB Onboarding Form' },
    t2: { url: 'https://tally.so/r/yPqR4X', label: 'Tier 2 — Built · Website Onboarding Form' },
    t3: { url: 'https://tally.so/r/VL1AJy', label: 'Tier 3 — Established · Website + GMB Onboarding Form' },
    t4: { url: 'https://tally.so/r/ODB95g', label: 'Tier 4 — Dominant · Full Year Onboarding Form' }
  };
  var tallyInfo = tallyLinks[pkg] || tallyLinks['t1'];
  var tallyDiv = document.getElementById('ob-tally-link');
  var tallyUrl = document.getElementById('ob-tally-url');
  var tallyLbl = document.getElementById('ob-tally-pkg-label');
  if(tallyDiv) tallyDiv.style.display = 'block';
  if(tallyUrl) { tallyUrl.href = tallyInfo.url; tallyUrl.textContent = tallyInfo.url; }
  if(tallyLbl) tallyLbl.textContent = tallyInfo.label;
  document.getElementById('ob-output').scrollIntoView({behavior:'smooth', block:'start'});
}

function obCopy(){
  var text = document.getElementById('ob-email-text').textContent;
  var btn  = document.getElementById('ob-copy-btn');
  navigator.clipboard.writeText(text).then(function(){
    btn.textContent = '\u2713 Copied';
    btn.style.background = 'var(--gr)';
    setTimeout(function(){ btn.textContent = 'Copy Email'; btn.style.background = ''; }, 2500);
  }).catch(function(){
    var ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = '\u2713 Copied';
    setTimeout(function(){ btn.textContent = 'Copy Email'; }, 2500);
  });
}

function obCopyTally(){
  var el = document.getElementById('ob-tally-url');
  var url = el ? el.href : '';
  if(!url || url === window.location.href) return;
  var btn = document.getElementById('ob-tally-copy');
  navigator.clipboard.writeText(url).then(function(){
    if(btn){ btn.textContent = '\u2713 Copied'; btn.style.background = 'var(--gr)';
      setTimeout(function(){ btn.textContent = 'Copy Link'; btn.style.background = ''; }, 2500); }
  }).catch(function(){
    var ta = document.createElement('textarea'); ta.value = url;
    document.body.appendChild(ta); ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    if(btn){ btn.textContent = '\u2713 Copied'; setTimeout(function(){ btn.textContent = 'Copy Link'; }, 2500); }
  });
}

function updateWbCk(cb){
  var all     = document.querySelectorAll('#wb2-ck-card input[type=checkbox]');
  var checked = document.querySelectorAll('#wb2-ck-card input[type=checkbox]:checked').length;
  var total   = all.length;
  var pct     = total > 0 ? Math.round((checked / total) * 100) : 0;
  var n = document.getElementById('wb-ck-nums'); if(n) n.textContent = checked + ' / ' + total;
  var f = document.getElementById('wb-ck-fill'); if(f) f.style.width = pct + '%';
  var p = document.getElementById('wb-ck-pct');  if(p) p.textContent = pct + '%';
  try {
    var state = [];
    all.forEach(function(c){ state.push(c.checked); });
    localStorage.setItem('wb_ck', JSON.stringify(state));
  } catch(e){}
}
function resetWbCk(){
  document.querySelectorAll('#wb2-ck-card input[type=checkbox]').forEach(function(cb){ cb.checked = false; });
  var n = document.getElementById('wb-ck-nums'); if(n) n.textContent = '0 / 32';
  var f = document.getElementById('wb-ck-fill'); if(f) f.style.width = '0%';
  var p = document.getElementById('wb-ck-pct');  if(p) p.textContent = '0%';
  try { localStorage.removeItem('wb_ck'); } catch(e){}
}
// Restore wb checklist on load
window.addEventListener('load', function(){
  try {
    var s = localStorage.getItem('wb_ck');
    if(s){
      var ws  = JSON.parse(s);
      var cbs = document.querySelectorAll('#wb2-ck-card input[type=checkbox]');
      cbs.forEach(function(cb, i){ if(ws[i]) cb.checked = true; });
      updateWbCk();
    }
  } catch(e){}
});
</script>
