<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>MT Trade Sites — Hub v13</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<style>
:root{
  --navy:#0a1628;--nm:#111f38;--nl:#1a2f50;
  --blue:#2d9bda;--bb:#45b3f5;--bp:#e8f4fd;
  --grey:#f2f5f9;--gm:#cdd5e0;--tx:#1a2b42;--tl:#5a6a7e;
  --gr:#22c55e;--am:#f59e0b;--rd:#ef4444;
  --fh:'Syne',sans-serif;--fb:'DM Sans',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:var(--fb);background:var(--grey);color:var(--tx);}

/* ── HEADER ── */
.hdr{background:var(--navy);height:58px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:300;box-shadow:0 2px 20px rgba(0,0,0,.45);}
.logo-area{display:flex;align-items:center;gap:10px;}
.logo-text{font-family:var(--fh);color:#fff;font-weight:700;font-size:15px;}
.logo-tag{color:var(--bb);font-size:10px;display:block;}
.hdr-pill{background:rgba(45,155,218,.2);border:1px solid rgba(45,155,218,.4);color:var(--bb);padding:3px 11px;border-radius:20px;font-size:11px;font-weight:600;}

/* ── NAV ── */
.navwrap{background:var(--nm);border-bottom:1px solid var(--nl);overflow-x:auto;position:sticky;top:58px;z-index:200;}
.nav{display:flex;padding:0 16px;min-width:max-content;}
.nb{padding:11px 14px;color:#7a8fa6;font-size:12px;font-weight:500;cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;white-space:nowrap;font-family:var(--fb);transition:color .15s;}
.nb:hover{color:var(--bb);}
.nb.active{color:#fff;border-bottom-color:var(--blue);font-weight:600;}
.nb.featured{color:var(--bb);}
.nb.featured.active{color:#fff;}

/* ── MAIN ── */
.main{max-width:1160px;margin:0 auto;padding:24px 18px;}
.sec{display:none;animation:fi .22s ease;}
.sec.active{display:block;}
@keyframes fi{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:none;}}
@keyframes orFadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

/* ── CARDS ── */
.card{background:#fff;border-radius:14px;padding:26px;margin-bottom:18px;box-shadow:0 1px 4px rgba(0,0,0,.05),0 4px 16px rgba(0,0,0,.04);}
.card-hd{display:flex;align-items:center;gap:11px;margin-bottom:20px;}
.card-icon{width:36px;height:36px;background:var(--bp);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.card-title{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--navy);}
.card-sub{font-size:11px;color:var(--tl);margin-top:1px;}

/* ── FORM ELEMENTS ── */
.fl{display:block;font-size:10px;font-weight:700;color:var(--tl);margin-bottom:5px;text-transform:uppercase;letter-spacing:.6px;font-family:var(--fh);}
.fi{width:100%;padding:10px 13px;border:1.5px solid var(--gm);border-radius:9px;font-size:13px;color:var(--tx);background:#fff;font-family:var(--fb);transition:border-color .15s,box-shadow .15s;}
.fi:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(45,155,218,.1);}
textarea.fi{min-height:80px;resize:vertical;line-height:1.6;}
.fsel{width:100%;padding:10px 13px;border:1.5px solid var(--gm);border-radius:9px;font-size:13px;color:var(--tx);background:#fff;font-family:var(--fb);cursor:pointer;}
.btn{padding:11px 22px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:var(--fb);transition:all .15s;}
.btn-p{background:var(--blue);color:#fff;}
.btn-p:hover{background:var(--bb);}
.btn-o{background:#fff;border:2px solid var(--blue);color:var(--blue);}
.btn-o:hover{background:var(--bp);}
.btn-g{background:var(--grey);border:1.5px solid var(--gm);color:var(--tl);}
.btn-g:hover{border-color:var(--blue);color:var(--blue);}

/* ── UTILS ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.ibox{background:var(--bp);border-left:3px solid var(--blue);border-radius:0 9px 9px 0;padding:13px 16px;margin-bottom:18px;}
.ibox p,.ibox{font-size:12.5px;color:var(--navy);line-height:1.6;}
.wbox{background:#fffbeb;border-left:3px solid var(--am);border-radius:0 9px 9px 0;padding:13px 16px;margin-bottom:14px;font-size:12.5px;color:#78350f;}
.sbox{background:linear-gradient(135deg,var(--navy),var(--nl));border-radius:11px;padding:18px;color:#fff;}
.snum{font-family:var(--fh);font-size:28px;font-weight:800;color:var(--bb);}
.slbl{font-size:11px;color:#7a8fa6;margin-top:3px;}
.divider{height:1px;background:var(--gm);margin:18px 0;}
.tag{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:2px 8px;border-radius:5px;}
.tag-blue{background:var(--bp);color:var(--blue);}
.tag-green{background:#dcfce7;color:#166534;}
.tag-amber{background:#fef3c7;color:#92400e;}
p{font-size:13px;line-height:1.7;color:var(--tx);}
h3{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--navy);margin-bottom:8px;}
h4{font-family:var(--fh);font-size:13px;font-weight:600;color:var(--navy);margin-bottom:5px;}

/* ── TAB BAR ── */
.tbar{display:flex;gap:6px;margin-bottom:20px;flex-wrap:wrap;}
.tb{padding:7px 15px;border-radius:8px;border:1.5px solid var(--gm);background:#fff;color:var(--tl);font-size:12px;font-weight:500;cursor:pointer;font-family:var(--fb);transition:all .15s;}
.tb:hover{border-color:var(--blue);color:var(--blue);}
.tb.active{background:var(--blue);border-color:var(--blue);color:#fff;font-weight:600;}
.tp{display:none;}
.tp.active{display:block;}

/* ── ACCORDION ── */
.acc{border:1.5px solid var(--gm);border-radius:11px;margin-bottom:8px;overflow:hidden;}
.acc-h{padding:14px 18px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;background:#fff;font-weight:600;color:var(--navy);font-size:13.5px;}
.acc-h:hover{background:var(--bp);}
.acc-body{display:none;padding:15px 18px;border-top:1px solid var(--gm);background:var(--grey);font-size:13px;line-height:1.8;}
.acc-body.open{display:block;}
.acc-arr{transition:transform .2s;color:var(--blue);}
.acc-arr.open{transform:rotate(180deg);}

/* ── CHECKLIST ── */
.chi{display:flex;align-items:flex-start;gap:11px;padding:8px 0;border-bottom:1px solid var(--grey);}
.chi:last-child{border-bottom:none;}
.chi input[type=checkbox]{margin-top:2px;width:16px;height:16px;cursor:pointer;accent-color:var(--blue);flex-shrink:0;}
.chi label{font-size:13px;cursor:pointer;line-height:1.5;}
.chi label.ck{text-decoration:line-through;color:var(--tl);}
.csec{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--blue);margin:16px 0 7px;font-family:var(--fh);}

/* ── STEPS ── */
.step{display:flex;gap:14px;margin-bottom:16px;}
.step-n{width:30px;height:30px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:13px;flex-shrink:0;}
.step-t{font-weight:600;color:var(--navy);margin-bottom:3px;font-family:var(--fh);font-size:14px;}
.step-d{font-size:12.5px;color:var(--tl);line-height:1.6;}

/* ── SCRIPT BOX ── */
.sbox2{background:var(--grey);border-left:3px solid var(--blue);border-radius:0 10px 10px 0;padding:14px 16px;margin-bottom:10px;position:relative;}
.sbox2-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--blue);margin-bottom:6px;font-family:var(--fh);}
.sbox2-txt{font-size:13px;line-height:1.75;color:var(--tx);white-space:pre-wrap;}
.copy-btn{position:absolute;top:10px;right:10px;background:var(--blue);color:#fff;border:none;padding:3px 11px;border-radius:6px;font-size:11px;cursor:pointer;font-family:var(--fb);}
.copy-btn:hover{background:var(--bb);}

@media(max-width:768px){.g2,.g3{grid-template-columns:1fr;}.main{padding:12px;}.or-grid{grid-template-columns:1fr;}}

/* ── OUTREACH SECTION ── */
.or-drop{border:2px dashed var(--gm);border-radius:14px;padding:52px 24px;text-align:center;cursor:pointer;background:#fff;transition:all .15s;}
.or-drop:hover,.or-drop.drag{border-color:var(--blue);background:var(--bp);}
.or-drop-icon{font-size:32px;margin-bottom:12px;}
.or-drop-title{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--navy);margin-bottom:5px;}
.or-drop-sub{font-size:12px;color:var(--tl);}
.or-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;}
.or-info-row{display:flex;align-items:center;justify-content:space-between;}
.or-info-left{display:flex;align-items:center;gap:8px;min-width:0;flex:1;}
.or-info-icon{font-size:13px;width:18px;text-align:center;flex-shrink:0;}
.or-info-val{font-size:13px;font-weight:600;color:var(--tx);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.or-info-link{font-size:13px;color:var(--blue);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-decoration:none;}
.or-copy{background:var(--blue);color:#fff;border:none;padding:4px 12px;border-radius:6px;font-size:11px;cursor:pointer;font-family:var(--fb);font-weight:600;white-space:nowrap;transition:background .12s;}
.or-copy:hover{background:var(--bb);}
.or-copy.copied{background:var(--gr);}
.or-nav{display:flex;justify-content:space-between;align-items:center;}
.or-arrow{width:36px;height:34px;display:flex;align-items:center;justify-content:center;border:1.5px solid var(--gm);border-radius:8px;background:#fff;font-size:15px;cursor:pointer;color:var(--tx);transition:all .12s;}
.or-arrow:hover:not(:disabled){border-color:var(--blue);color:var(--blue);background:var(--bp);}
.or-arrow:disabled{opacity:.3;cursor:not-allowed;}
.or-stars{color:#d97706;font-size:13px;letter-spacing:1px;}
.or-pill-cat{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--tl);margin-bottom:5px;font-family:var(--fh);margin-top:10px;}
.or-pill-cat:first-child{margin-top:0;}
.or-pill-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:2px;}
.or-pill{font-size:11.5px;padding:4px 10px;border-radius:16px;border:1.5px solid var(--gm);background:#fff;color:var(--tl);cursor:pointer;position:relative;font-family:var(--fb);transition:all .12s;white-space:nowrap;}
.or-pill:hover{border-color:var(--blue);color:var(--blue);background:var(--bp);}
.or-pill.on{border-color:var(--blue);background:var(--bp);color:var(--blue);font-weight:600;}
.or-dot{position:absolute;top:-3px;right:-3px;width:7px;height:7px;background:var(--am);border-radius:50%;display:block;border:1px solid #fff;}
.or-msg{width:100%;padding:12px 14px;border:1.5px solid var(--gm);border-radius:9px;font-size:13px;font-family:var(--fb);color:var(--tx);line-height:1.75;resize:none;background:var(--grey);transition:border .15s;}
.or-msg:focus{outline:none;border-color:var(--blue);background:#fff;}
.or-actions{display:flex;gap:7px;flex-wrap:wrap;}
.or-btn-sent{flex:2;min-width:130px;background:var(--gr);color:#fff;border:none;border-radius:9px;padding:11px 0;font-weight:700;font-size:13px;cursor:pointer;font-family:var(--fh);transition:background .15s;}
.or-btn-sent:hover{background:#16a34a;}
.or-btn-ghost{flex:1;min-width:60px;background:#fff;border:1.5px solid var(--gm);border-radius:9px;padding:10px 0;font-size:12px;color:var(--tl);cursor:pointer;font-family:var(--fb);transition:all .12s;}
.or-btn-ghost:hover{border-color:var(--blue);color:var(--blue);}
.or-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:12px;text-transform:uppercase;letter-spacing:.4px;white-space:nowrap;font-family:var(--fh);}
.or-badge-pending{background:rgba(255,255,255,.12);color:rgba(255,255,255,.6);}
.or-badge-sent{background:#dcfce7;color:#166534;}
.or-badge-skipped{background:#fef3c7;color:#92400e;}
.or-badge-no{background:#fee2e2;color:#991b1b;}
.or-badge-follow_up{background:#e0e7ff;color:#3730a3;}
.or-prog-track{height:5px;background:var(--gm);border-radius:3px;overflow:hidden;}
.or-prog-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--gr));border-radius:3px;transition:width .4s ease;}
.or-snippet{font-size:12px;color:var(--tl);font-style:italic;padding:8px 11px;background:var(--grey);border-radius:8px;line-height:1.5;}
.or-log-row{background:#fff;border:1.5px solid var(--gm);border-radius:10px;padding:12px 14px;margin-bottom:7px;}
.or-log-top{display:flex;justify-content:space-between;margin-bottom:3px;}
.or-log-name{font-weight:700;font-size:13.5px;color:var(--navy);}
.or-log-ts{font-size:11px;color:var(--tl);}
.or-log-meta{font-size:12px;color:var(--tl);}
.or-log-gaps{font-size:12px;color:var(--blue);margin-top:2px;}
.or-tone-btn{font-size:11px;padding:5px 12px;border:none;border-radius:6px;background:transparent;color:var(--tl);cursor:pointer;font-family:var(--fb);font-weight:500;transition:all .12s;}
.or-tone-btn.active{background:#fff;color:var(--blue);font-weight:700;box-shadow:0 1px 4px rgba(0,0,0,.1);}

/* ── OUTREACH SECTION ── */
.or-drop{border:2px dashed var(--gm);border-radius:12px;padding:44px 24px;text-align:center;cursor:pointer;background:#fff;transition:all .15s;}
.or-drop:hover,.or-drop.drag{border-color:var(--blue);background:var(--bp);}
.or-drop-icon{font-size:30px;margin-bottom:10px;}
.or-drop-title{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.or-drop-sub{font-size:12px;color:var(--tl);}
.or-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;}
.or-info-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--grey);}
.or-info-row:last-child{border-bottom:none;}
.or-info-left{display:flex;align-items:center;gap:8px;min-width:0;flex:1;}
.or-info-icon{font-size:13px;width:18px;text-align:center;flex-shrink:0;}
.or-info-val{font-size:13px;font-weight:600;color:var(--tx);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.or-info-link{font-size:13px;color:var(--blue);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-decoration:none;}
.or-copy{background:var(--blue);color:#fff;border:none;padding:3px 11px;border-radius:6px;font-size:11px;cursor:pointer;font-family:var(--fb);flex-shrink:0;margin-left:8px;white-space:nowrap;}
.or-copy:hover{background:var(--bb);}
.or-nav{display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:12px;border-top:1px solid var(--grey);}
.or-arrow{width:34px;height:32px;border:1.5px solid var(--gm);border-radius:8px;background:#fff;color:var(--tx);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.or-arrow:hover:not(:disabled){border-color:var(--blue);color:var(--blue);}
.or-arrow:disabled{opacity:.3;cursor:not-allowed;}
.or-stars{color:var(--am);font-size:12px;}
.or-pill-row{display:flex;flex-wrap:wrap;gap:6px;}
.or-pill{font-size:12px;padding:5px 11px;border-radius:20px;border:1.5px solid var(--gm);background:#fff;color:var(--tl);cursor:pointer;position:relative;font-family:var(--fb);transition:all .15s;}
.or-pill:hover{border-color:var(--blue);color:var(--blue);}
.or-pill.on{border-color:var(--blue);background:var(--bp);color:var(--blue);font-weight:600;}
.or-dot{position:absolute;top:-3px;right:-3px;width:7px;height:7px;background:var(--am);border-radius:50%;display:block;}
.or-msg{width:100%;padding:12px 14px;border:1.5px solid var(--gm);border-radius:9px;font-size:13px;font-family:var(--fb);color:var(--tx);line-height:1.7;min-height:168px;resize:none;background:var(--grey);}
.or-msg:focus{outline:none;border-color:var(--blue);background:#fff;}
.or-actions{display:flex;gap:8px;margin-top:4px;}
.or-btn-sent{flex:2;background:var(--gr);color:#fff;border:none;border-radius:9px;padding:10px 0;font-weight:700;font-size:13px;cursor:pointer;font-family:var(--fb);}
.or-btn-sent:hover{background:#16a34a;}
.or-btn-ghost{flex:1;background:#fff;border:1.5px solid var(--gm);border-radius:9px;padding:10px 0;font-size:13px;color:var(--tl);cursor:pointer;font-family:var(--fb);}
.or-btn-ghost:hover{border-color:var(--blue);color:var(--blue);}
.or-badge{font-size:10px;font-weight:700;padding:2px 9px;border-radius:12px;text-transform:uppercase;letter-spacing:.4px;white-space:nowrap;}
.or-badge-pending{background:var(--grey);color:var(--tl);}
.or-badge-sent{background:#dcfce7;color:#166534;}
.or-badge-skipped{background:#fef3c7;color:#92400e;}
.or-badge-no{background:#fee2e2;color:#991b1b;}
.or-prog-track{height:4px;background:var(--gm);border-radius:2px;overflow:hidden;margin:6px 0 4px;}
.or-prog-fill{height:100%;background:var(--gr);border-radius:2px;transition:width .3s;}
.or-snippet{font-size:12px;color:var(--tl);font-style:italic;padding:8px 11px;background:var(--grey);border-radius:8px;margin-bottom:10px;line-height:1.5;}
.or-log-row{background:#fff;border:1.5px solid var(--gm);border-radius:10px;padding:12px 14px;margin-bottom:7px;}
.or-log-top{display:flex;justify-content:space-between;margin-bottom:3px;}
.or-log-name{font-weight:700;font-size:13.5px;color:var(--navy);}
.or-log-ts{font-size:11px;color:var(--tl);}
.or-log-meta{font-size:12px;color:var(--tl);}
.or-log-gaps{font-size:12px;color:var(--blue);margin-top:2px;}

/* ════════════════════════════════════════════════════════
   REVIEW CARD MAKER — PRODUCT STYLES
════════════════════════════════════════════════════════ */
.rc-shell{display:grid;grid-template-columns:340px 1fr;gap:0;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 30px rgba(0,0,0,.08);min-height:680px;}
.rc-sidebar{background:#f8fafc;border-right:1px solid #e8edf4;padding:24px;display:flex;flex-direction:column;gap:0;overflow-y:auto;}
.rc-preview-area{background:#f0f4f8;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:32px 24px;gap:20px;position:relative;}
.rc-preview-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--tl);font-family:var(--fh);}

/* Why panel */
.rc-why{background:linear-gradient(135deg,var(--navy),var(--nl));border-radius:12px;padding:18px 20px;margin-bottom:20px;}
.rc-why-title{font-family:var(--fh);font-size:11px;font-weight:700;color:var(--bb);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;}
.rc-stat{display:flex;align-items:center;gap:10px;padding:6px 0;}
.rc-stat-num{font-family:var(--fh);font-size:22px;font-weight:800;color:#fff;min-width:48px;}
.rc-stat-txt{font-size:12px;color:rgba(255,255,255,.7);line-height:1.4;}

/* Layout picker */
.rc-layout-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:18px;}
.rc-lay-btn{border:2px solid var(--gm);border-radius:10px;padding:10px 6px 8px;cursor:pointer;background:#fff;text-align:center;transition:all .15s;}
.rc-lay-btn:hover{border-color:var(--blue);}
.rc-lay-btn.on{border-color:var(--blue);background:var(--bp);}
.rc-lay-thumb{width:100%;height:52px;border-radius:6px;overflow:hidden;margin-bottom:6px;display:flex;}
.rc-lay-name{font-size:10px;font-weight:700;font-family:var(--fh);color:var(--navy);}

/* Colour presets */
.rc-col-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:8px;}
.rc-col-swatch{width:28px;height:28px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .15s;flex-shrink:0;}
.rc-col-swatch:hover,.rc-col-swatch.on{border-color:var(--blue);transform:scale(1.12);}

/* Section headers in sidebar */
.rc-section{margin-bottom:18px;}
.rc-section-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--tl);font-family:var(--fh);margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--gm);}

/* Progress indicator */
.rc-progress{display:flex;gap:8px;margin-bottom:24px;}
.rc-step-dot{flex:1;height:3px;border-radius:2px;background:var(--gm);transition:background .3s;}
.rc-step-dot.done{background:var(--gr);}
.rc-step-dot.active{background:var(--blue);}

/* Education callout */
.rc-edu{background:linear-gradient(135deg,#f0f9ff,#e0f2fe);border:1px solid #bae6fd;border-radius:10px;padding:14px 16px;margin-bottom:18px;}
.rc-edu-icon{font-size:18px;margin-bottom:6px;}
.rc-edu-title{font-family:var(--fh);font-size:12px;font-weight:700;color:#0c4a6e;margin-bottom:4px;}
.rc-edu-text{font-size:12px;color:#075985;line-height:1.5;}

/* Download strip */
.rc-dl-strip{background:var(--navy);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.rc-dl-strip-txt{font-family:var(--fh);font-size:12px;color:rgba(255,255,255,.6);}
.rc-dl-btns{display:flex;gap:8px;}
.rc-dl-btn{padding:8px 18px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;border:none;font-family:var(--fh);letter-spacing:.3px;}
.rc-dl-primary{background:var(--blue);color:#fff;}
.rc-dl-primary:hover{background:var(--bb);}
.rc-dl-sec{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;}
.rc-dl-sec:hover{background:rgba(255,255,255,.18);}

/* ── CARD RENDERS ── */
/* Authority */
.rc-authority{border-radius:14px;overflow:hidden;width:280px;box-shadow:0 8px 40px rgba(0,0,0,.18);}
.rc-authority .rc-top{padding:26px 20px 18px;text-align:center;position:relative;}
.rc-authority .rc-logo-wrap{width:76px;height:76px;border-radius:50%;margin:0 auto 12px;display:flex;align-items:center;justify-content:center;overflow:hidden;border:2px solid rgba(255,255,255,.15);}
.rc-authority .rc-biz{font-family:var(--fh);font-size:17px;font-weight:800;color:#fff;margin-bottom:2px;}
.rc-authority .rc-trade{font-size:10px;color:rgba(255,255,255,.5);margin-bottom:14px;text-transform:uppercase;letter-spacing:1.5px;}
.rc-authority .rc-stars{display:flex;justify-content:center;gap:3px;margin-bottom:14px;font-size:18px;}
.rc-authority .rc-cta{font-family:var(--fh);font-size:13px;font-weight:700;color:#fff;margin-bottom:5px;}
.rc-authority .rc-ctasub{font-size:11px;color:rgba(255,255,255,.6);line-height:1.5;margin-bottom:14px;}
.rc-authority .rc-offer{display:none;border-radius:7px;padding:7px 11px;font-size:11px;font-weight:700;margin-bottom:12px;text-align:center;}
.rc-authority .rc-bottom{background:#fff;padding:18px 20px;text-align:center;}
.rc-authority .rc-qr-wrap{width:120px;height:120px;margin:0 auto 8px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:var(--grey);}
.rc-authority .rc-scan{font-size:11px;color:var(--tl);}

/* Split */
.rc-split{border-radius:14px;overflow:hidden;width:300px;box-shadow:0 8px 40px rgba(0,0,0,.18);display:grid;grid-template-columns:1fr 1fr;}
.rc-split .rc-left{padding:22px 16px;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;}
.rc-split .rc-logo-wrap{width:60px;height:60px;border-radius:9px;margin-bottom:10px;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.rc-split .rc-biz{font-family:var(--fh);font-size:13px;font-weight:800;color:#fff;margin-bottom:2px;line-height:1.2;}
.rc-split .rc-trade{font-size:9px;color:rgba(255,255,255,.45);margin-bottom:10px;}
.rc-split .rc-stars{display:flex;gap:2px;justify-content:center;font-size:13px;margin-bottom:8px;}
.rc-split .rc-offer{display:none;border-radius:5px;padding:4px 7px;font-size:9px;font-weight:700;color:#fcd34d;text-align:center;border:1px solid rgba(245,158,11,.4);}
.rc-split .rc-right{background:#fff;padding:22px 16px;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;}
.rc-split .rc-cta{font-family:var(--fh);font-size:12px;font-weight:800;color:var(--navy);margin-bottom:7px;line-height:1.3;}
.rc-split .rc-ctasub{font-size:10px;color:var(--tl);margin-bottom:12px;line-height:1.4;}
.rc-split .rc-qr-wrap{width:96px;height:96px;margin:0 auto 6px;border-radius:6px;display:flex;align-items:center;justify-content:center;background:var(--grey);}
.rc-split .rc-scan{font-size:9.5px;color:var(--tl);}

/* Bold */
.rc-bold{border-radius:14px;overflow:hidden;width:272px;box-shadow:0 8px 40px rgba(0,0,0,.18);}
.rc-bold .rc-top{padding:20px 18px 14px;position:relative;overflow:hidden;}
.rc-bold .rc-top-deco1{position:absolute;top:-28px;right:-28px;width:110px;height:110px;border-radius:50%;opacity:.05;}
.rc-bold .rc-top-deco2{position:absolute;bottom:-18px;left:-18px;width:75px;height:75px;border-radius:50%;opacity:.04;}
.rc-bold .rc-hrow{display:flex;align-items:center;gap:11px;margin-bottom:14px;position:relative;}
.rc-bold .rc-logo-wrap{width:50px;height:50px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.rc-bold .rc-biz{font-family:var(--fh);font-size:16px;font-weight:800;color:#fff;line-height:1.2;}
.rc-bold .rc-trade{font-size:10px;color:rgba(255,255,255,.5);margin-top:2px;}
.rc-bold .rc-panel{border-radius:8px;padding:12px 13px;margin-bottom:10px;position:relative;}
.rc-bold .rc-cta{font-family:var(--fh);font-size:17px;font-weight:800;color:#fff;margin-bottom:3px;}
.rc-bold .rc-ctasub{font-size:10.5px;color:rgba(255,255,255,.55);line-height:1.5;}
.rc-bold .rc-stars{display:flex;gap:2px;margin-top:7px;font-size:15px;}
.rc-bold .rc-offer{display:none;border-radius:6px;padding:6px 10px;font-size:10.5px;font-weight:700;color:#fcd34d;margin-bottom:10px;position:relative;}
.rc-bold .rc-bottom{background:#fff;padding:16px 18px;text-align:center;}
.rc-bold .rc-qr-wrap{width:108px;height:108px;margin:0 auto 7px;border-radius:7px;display:flex;align-items:center;justify-content:center;background:var(--grey);}
.rc-bold .rc-scan{font-size:10px;color:var(--tl);}

/* ── REVIEW STEP FLOW ── */
.rc-flow-steps{display:flex;flex-direction:column;gap:2px;margin-bottom:20px;}
.rc-flow-step{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:9px;cursor:pointer;transition:all .15s;border:1.5px solid transparent;}
.rc-flow-step:hover{background:var(--bp);border-color:rgba(45,155,218,.2);}
.rc-flow-step.active{background:var(--bp);border-color:var(--blue);}
.rc-flow-step.done{opacity:.6;}
.rc-flow-num{width:24px;height:24px;border-radius:50%;background:var(--gm);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--tl);flex-shrink:0;font-family:var(--fh);}
.rc-flow-step.active .rc-flow-num{background:var(--blue);color:#fff;}
.rc-flow-step.done .rc-flow-num{background:var(--gr);color:#fff;}
.rc-flow-lbl{font-size:12px;font-weight:600;color:var(--navy);}
.rc-flow-step.active .rc-flow-lbl{color:var(--blue);}

/* Step panels */
.rc-step-panel{display:none;}
.rc-step-panel.active{display:block;}

/* ════════════════════════════════════════════════════════
   POST FACTORY — PRODUCT STYLES
════════════════════════════════════════════════════════ */
.pf-shell{display:grid;grid-template-columns:320px 1fr;gap:0;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 30px rgba(0,0,0,.08);}
.pf-sidebar{background:#f8fafc;border-right:1px solid #e8edf4;display:flex;flex-direction:column;overflow-y:auto;max-height:calc(100vh - 120px);}
.pf-sidebar-hd{padding:20px 22px 16px;border-bottom:1px solid #e8edf4;}
.pf-sidebar-body{padding:20px 22px;flex:1;overflow-y:auto;}
.pf-main{display:flex;flex-direction:column;overflow:hidden;}
.pf-topbar{padding:16px 22px;border-bottom:1px solid #e8edf4;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;background:#fff;}
.pf-canvas-area{flex:1;background:#ecf0f5;overflow-y:auto;padding:20px;min-height:0;}

/* Upload zone */
.pf-drop{border:2px dashed var(--gm);border-radius:12px;padding:28px 20px;text-align:center;cursor:pointer;background:#fff;transition:all .2s;}
.pf-drop:hover,.pf-drop.drag{border-color:var(--blue);background:var(--bp);}
.pf-drop-icon{font-size:30px;margin-bottom:8px;}
.pf-drop-title{font-family:var(--fh);font-size:13px;font-weight:700;color:var(--blue);margin-bottom:2px;}
.pf-drop-sub{font-size:11px;color:var(--tl);}

/* Style and layout pickers */
.pf-pick-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:18px;}
.pf-pick-btn{border:2px solid var(--gm);border-radius:9px;padding:8px 7px 6px;cursor:pointer;background:#fff;text-align:center;transition:all .15s;}
.pf-pick-btn:hover{border-color:var(--blue);}
.pf-pick-btn.on{border-color:var(--blue);background:var(--bp);}
.pf-pick-thumb{width:100%;height:42px;border-radius:5px;margin-bottom:5px;overflow:hidden;}
.pf-pick-name{font-size:10px;font-weight:700;font-family:var(--fh);color:var(--navy);}
.pf-pick-sub{font-size:9px;color:var(--tl);margin-top:1px;}

/* Image bank */
.pf-imgbank{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:12px;}
.pf-img-thumb{aspect-ratio:1;border-radius:6px;overflow:hidden;cursor:pointer;border:2px solid transparent;transition:all .15s;position:relative;}
.pf-img-thumb:hover{border-color:var(--blue);}
.pf-img-thumb.on{border-color:var(--blue);}
.pf-img-thumb img{width:100%;height:100%;object-fit:cover;}
.pf-img-thumb .pf-img-del{position:absolute;top:3px;right:3px;width:18px;height:18px;background:rgba(239,68,68,.85);border-radius:50%;display:none;align-items:center;justify-content:center;font-size:10px;color:#fff;font-weight:700;cursor:pointer;}
.pf-img-thumb:hover .pf-img-del{display:flex;}
.pf-img-add{aspect-ratio:1;border-radius:6px;border:2px dashed var(--gm);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;gap:2px;background:#fff;transition:all .15s;}
.pf-img-add:hover{border-color:var(--blue);background:var(--bp);}
.pf-img-add-icon{font-size:20px;color:var(--gm);}
.pf-img-add-txt{font-size:9px;color:var(--tl);font-weight:600;font-family:var(--fh);}

/* Gallery */
.pf-gal{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;}
.pf-gal-card{background:#fff;border-radius:10px;overflow:hidden;border:1.5px solid var(--gm);transition:box-shadow .15s;}
.pf-gal-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.1);}
.pf-gal-foot{padding:9px 10px 10px;}
.pf-gal-cat{font-size:9px;font-weight:700;text-transform:uppercase;color:var(--blue);margin-bottom:3px;font-family:var(--fh);}
.pf-gal-head{font-size:11px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.pf-dl-one{width:100%;padding:5px;background:var(--bp);color:var(--blue);border:none;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;font-family:var(--fb);}
.pf-dl-one:hover{background:var(--blue);color:#fff;}

/* Status bar */
.pf-status-bar{padding:10px 22px;background:var(--grey);border-top:1px solid #e8edf4;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.pf-progress-wrap{flex:1;min-width:120px;height:4px;background:var(--gm);border-radius:3px;overflow:hidden;}
.pf-progress-fill{height:100%;background:var(--blue);width:0%;transition:width .2s;}
.pf-status-txt{font-size:11.5px;color:var(--tl);}

/* Safety net callout */
.pf-safety{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1px solid #86efac;border-radius:10px;padding:14px 16px;margin-bottom:16px;}
.pf-safety-title{font-family:var(--fh);font-size:11px;font-weight:700;color:#166534;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.pf-safety-txt{font-size:12px;color:#166534;line-height:1.5;}

/* Section label */
.pf-sec-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--tl);font-family:var(--fh);margin-bottom:8px;margin-top:16px;}
.pf-sec-lbl:first-child{margin-top:0;}

/* Empty gallery state */
.pf-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:300px;gap:10px;color:var(--tl);}
.pf-empty-icon{font-size:36px;opacity:.4;}
.pf-empty-title{font-family:var(--fh);font-size:14px;font-weight:700;opacity:.5;}
.pf-empty-sub{font-size:12px;opacity:.4;text-align:center;max-width:240px;line-height:1.5;}

/* Topbar tools */
.pf-topbar-title{font-family:var(--fh);font-size:14px;font-weight:800;color:var(--navy);}
.pf-topbar-right{display:flex;gap:8px;align-items:center;}

/* ── DASHBOARD / GENERIC ── */
.cnote{background:linear-gradient(135deg,#e8f4fd,#f0f8ff);border-left:4px solid var(--blue);border-radius:0 11px 11px 0;padding:16px 20px;margin-bottom:16px;}
.cnote strong{display:block;font-family:var(--fh);color:var(--navy);margin-bottom:5px;}
.pbox{background:linear-gradient(135deg,var(--navy),var(--nl));border-radius:12px;padding:22px;color:#fff;}
.pbox h3{font-family:var(--fh);color:var(--bb);font-size:11px;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;}
.bul{display:flex;align-items:flex-start;gap:9px;padding:4px 0;font-size:13px;color:rgba(255,255,255,.85);}
.bul::before{content:"→";color:var(--bb);font-weight:700;flex-shrink:0;}

/* PITCH DECK (kept from v11) */
.deckover{position:fixed;top:0;left:0;width:100%;height:100%;background:#f5f7fa;z-index:9999;display:none;flex-direction:column;}
.deckover.open{display:flex;}
.dtop{display:flex;align-items:center;justify-content:space-between;padding:13px 26px;background:rgba(10,22,40,.92);backdrop-filter:blur(10px);flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.06);}
.dbrand{font-family:var(--fh);font-size:11px;color:rgba(255,255,255,.45);letter-spacing:2px;text-transform:uppercase;}
.dctrls{display:flex;align-items:center;gap:14px;}
.dcnt{font-family:var(--fh);font-size:12px;color:rgba(255,255,255,.45);}
.dexit{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;padding:6px 14px;border-radius:16px;cursor:pointer;font-size:11.5px;font-family:var(--fb);}
.dexit:hover{background:rgba(255,255,255,.2);}
.dswrap{flex:1;position:relative;overflow:hidden;}
.dslide{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:56px 70px;text-align:center;opacity:0;transform:translateX(50px);transition:opacity .38s cubic-bezier(.4,0,.2,1),transform .38s cubic-bezier(.4,0,.2,1);pointer-events:none;}
.dslide.active{opacity:1;transform:none;pointer-events:all;}
.dslide.prev{opacity:0;transform:translateX(-50px);}
.dbot{display:flex;align-items:center;justify-content:center;gap:18px;padding:16px 26px;background:rgba(0,0,0,.15);flex-shrink:0;border-top:1px solid rgba(0,0,0,.08);}
.dnav{width:42px;height:42px;border-radius:50%;background:rgba(10,22,40,.15);border:1px solid rgba(10,22,40,.15);color:var(--navy);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.dnav:hover{background:var(--blue);border-color:var(--blue);color:#fff;}
.dnav:disabled{opacity:.3;cursor:not-allowed;}
.ddots{display:flex;gap:7px;align-items:center;}
.ddot{width:7px;height:7px;border-radius:50%;background:rgba(10,22,40,.2);cursor:pointer;}
.ddot.on{background:var(--blue);width:22px;border-radius:3px;}
.dtit{font-family:var(--fh);font-size:40px;font-weight:800;color:var(--navy);line-height:1.1;margin-bottom:16px;max-width:760px;}
.dtit .hl{color:var(--blue);}
.dbody{font-size:16px;color:rgba(10,22,40,.6);line-height:1.7;max-width:600px;}
.ey{font-family:var(--fh);font-size:10.5px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--blue);margin-bottom:14px;}

/* other hub sections preserved minimal */
.pkg{border-radius:12px;border:2px solid var(--gm);padding:22px;position:relative;background:#fff;}
.pkg.feat{border-color:var(--blue);box-shadow:0 4px 20px rgba(45,155,218,.12);}
.pbadge{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--blue);color:#fff;padding:2px 12px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap;}
.ptier{font-size:10px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:3px;font-family:var(--fh);}
.pname{font-family:var(--fh);font-size:20px;font-weight:800;color:var(--navy);}
.pprice{font-family:var(--fh);font-size:22px;font-weight:800;color:var(--navy);margin:10px 0 3px;}
.pprice span{font-size:12px;font-weight:400;color:var(--tl);font-family:var(--fb);}
.pdesc{font-size:12.5px;color:var(--tl);margin-bottom:12px;line-height:1.6;}
.plist{list-style:none;}
.plist li{font-size:12.5px;padding:3px 0;display:flex;gap:7px;}
.plist li::before{content:"✓";color:var(--gr);font-weight:700;flex-shrink:0;}
.ttab{width:100%;border-collapse:collapse;font-size:13px;}
.ttab th{background:var(--navy);color:#fff;padding:9px 13px;text-align:left;font-family:var(--fh);font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;}
.ttab td{padding:8px 13px;border-bottom:1px solid var(--grey);}
.ttab input{width:100%;border:none;background:transparent;font-size:13px;font-family:var(--fb);color:var(--tx);}
.ai{display:flex;align-items:flex-start;gap:10px;padding:8px 12px;border-radius:8px;margin-bottom:4px;background:#fff;border:1.5px solid var(--gm);}
.ai input[type=checkbox]{width:16px;height:16px;margin-top:2px;flex-shrink:0;accent-color:var(--blue);cursor:pointer;}
.ai label{font-size:12.5px;line-height:1.5;cursor:pointer;flex:1;}
.atag{font-size:9.5px;font-weight:700;text-transform:uppercase;padding:2px 7px;border-radius:4px;flex-shrink:0;margin-top:2px;}
.atag.fix{background:#fef2f2;color:var(--rd);}
.atag.wk{background:#fffbeb;color:var(--am);}
.ash{background:var(--navy);color:#fff;padding:10px 16px;border-radius:8px;margin-bottom:8px;font-family:var(--fh);font-size:13px;font-weight:700;}
.ccard{border:1.5px solid var(--gm);border-radius:11px;padding:18px;background:#fff;}
.ctrade{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--blue);font-family:var(--fh);}
.cname{font-family:var(--fh);font-size:17px;font-weight:700;color:var(--navy);margin:3px 0 10px;}
.prbox{background:var(--navy);border-radius:11px;padding:18px;color:#cdd5e0;font-size:12px;line-height:1.8;font-family:monospace;white-space:pre-wrap;position:relative;}
.mod{border:1.5px solid var(--gm);border-radius:11px;margin-bottom:8px;overflow:hidden;}
.mh{padding:14px 18px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;background:#fff;font-weight:600;color:var(--navy);font-family:var(--fh);font-size:13.5px;}
.mh:hover{background:var(--bp);}
.mb{display:none;padding:14px 18px;border-top:1px solid var(--gm);background:var(--grey);font-size:13px;line-height:1.8;}
.mb.open{display:block;}
.ma{transition:transform .2s;}
.ma.open{transform:rotate(180deg);}
.vg{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.vc{background:var(--bp);border-radius:10px;padding:16px;border-top:3px solid var(--blue);}
.vc h4{font-family:var(--fh);color:var(--blue);font-size:11px;text-transform:uppercase;letter-spacing:.5px;}
.vc p{font-size:12.5px;margin-top:5px;}
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.lbtn{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:15px;background:var(--blue);color:#fff;border:none;border-radius:11px;font-size:15px;font-weight:700;cursor:pointer;font-family:var(--fh);letter-spacing:.5px;margin-top:8px;}
.lbtn:hover{background:var(--bb);}
.ob{border:1.5px solid var(--gm);border-radius:10px;margin-bottom:7px;overflow:hidden;}
.oh{padding:13px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;background:#fff;font-weight:600;color:var(--navy);font-size:13.5px;}
.oh:hover{background:var(--bp);}
.obody{display:none;padding:14px 16px;border-top:1px solid var(--gm);background:var(--grey);font-size:13px;line-height:1.8;}
.obody.open{display:block;}
.oa{transition:transform .2s;color:var(--blue);}
.oa.open{transform:rotate(180deg);}
.onote{font-size:11px;color:var(--am);font-weight:600;font-style:italic;margin-top:6px;}
.rp{background:#fff;border-radius:12px;padding:24px;margin-top:18px;box-shadow:0 4px 20px rgba(0,0,0,.08);}
.rsc{font-family:var(--fh);font-size:48px;font-weight:800;color:var(--bb);}
.tst{background:var(--bp);border-radius:9px;padding:14px;text-align:center;}
.tnum{font-family:var(--fh);font-size:26px;font-weight:800;color:var(--blue);}
.tlbl{font-size:11px;color:var(--tl);margin-top:2px;}
.rbtn{background:none;border:1px solid var(--gm);color:var(--tl);padding:4px 11px;border-radius:6px;font-size:11px;cursor:pointer;}
.rbtn:hover{border-color:var(--blue);color:var(--blue);}
.sstep{display:flex;gap:14px;margin-bottom:16px;}
.sn{width:30px;height:30px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:13px;flex-shrink:0;}
.stit{font-weight:600;color:var(--navy);margin-bottom:3px;font-family:var(--fh);font-size:14px;}
.sdesc{font-size:12.5px;color:var(--tl);line-height:1.6;}
.rrow{display:flex;gap:10px;padding:9px 0;border-bottom:1px solid var(--grey);font-size:13px;}
.rrow:last-child{border-bottom:none;}
.rdot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.rdot.r{background:var(--rd);}
.rdot.a{background:var(--am);}
.rdot.g{background:var(--gr);}
.nb.hidden{display:none!important;}
.role-btn{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.7);padding:5px 14px;border-radius:18px;font-size:12px;cursor:pointer;font-family:var(--fb);transition:all .2s;}
.role-btn:hover{background:rgba(255,255,255,.15);color:#fff;}
.role-btn.active{background:var(--blue);border-color:var(--blue);color:#fff;font-weight:600;}

/* ── SLOT PLACEHOLDERS ── */
.slot-placeholder{
  border:2px dashed var(--gm);border-radius:16px;padding:48px 32px;
  text-align:center;background:#fff;position:relative;
  display:flex;flex-direction:column;align-items:center;gap:10px;
  max-width:560px;margin:40px auto;
}
.slot-icon{font-size:36px;line-height:1;}
.slot-title{font-family:var(--fh);font-size:20px;font-weight:800;color:var(--navy);}
.slot-sub{font-size:13px;color:var(--tl);line-height:1.6;max-width:380px;}
.slot-badge{
  position:absolute;top:-12px;left:50%;transform:translateX(-50%);
  padding:3px 14px;border-radius:20px;font-size:10px;font-weight:700;
  font-family:var(--fh);letter-spacing:.5px;white-space:nowrap;
}
.slot-badge-b1{background:var(--am);color:#fff;}
.slot-badge-b2{background:var(--navy);color:var(--bb);}


/* ── MISSING CSS: Scripts, Audit, Sendout sections ── */
.pb-wrap{font-family:'DM Sans',sans-serif;color:#1a2b42;}
.pb-header{background:linear-gradient(135deg,#061020,#0d1e38);border-radius:14px;padding:24px 28px;margin-bottom:0;position:relative;overflow:hidden;}
.pb-header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--blue);}
.pb-biz{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:#fff;line-height:1.2;}
.pb-sub{font-size:12px;color:rgba(255,255,255,.4);margin-top:4px;letter-spacing:.3px;}
.pb-brand{font-size:10px;color:rgba(255,255,255,.25);letter-spacing:2px;text-transform:uppercase;font-family:'Syne',sans-serif;}
.pb-intro{background:#fff;border:1px solid #e8eef4;border-radius:0 0 12px 12px;padding:18px 22px;margin-bottom:18px;border-top:none;}
.pb-intro-txt{font-size:13.5px;line-height:1.8;color:#374a60;}
.pb-section{border-radius:12px;overflow:hidden;margin-bottom:14px;}
.pb-sec-head{padding:12px 18px;display:flex;align-items:center;gap:10px;}
.pb-sec-icon{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.pb-sec-title{font-family:'Syne',sans-serif;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;}
.pb-sec-sub{font-size:10px;opacity:.6;margin-top:1px;}
.pb-sec-body{background:#fff;border:1px solid;border-top:none;border-radius:0 0 12px 12px;padding:14px 18px;}
.pb-once .pb-sec-head{background:linear-gradient(135deg,#1a0505,#3a0c0c);}
.pb-once .pb-sec-title{color:#fca5a5;}
.pb-once .pb-sec-icon{background:rgba(239,68,68,.2);}
.pb-once .pb-sec-body{border-color:#fecaca;}
.pb-weekly .pb-sec-head{background:linear-gradient(135deg,#1a1200,#3a2800);}
.pb-weekly .pb-sec-title{color:#fcd34d;}
.pb-weekly .pb-sec-icon{background:rgba(245,158,11,.2);}
.pb-weekly .pb-sec-body{border-color:#fde68a;}
.pb-pkg-box{background:linear-gradient(135deg,#e8f4fd,#f0f8ff);border:2px solid var(--blue);border-radius:12px;padding:16px 20px;margin-bottom:14px;}
.pb-pkg-label{font-family:'Syne',sans-serif;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--blue);margin-bottom:6px;}
.pb-pkg-name{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--navy);}
.pb-pkg-note{font-size:12px;color:var(--tl);margin-top:5px;line-height:1.5;}
.pb-task{display:flex;align-items:flex-start;gap:12px;padding:9px 0;border-bottom:1px solid rgba(0,0,0,.04);font-size:13px;color:#1a2b42;line-height:1.5;}
.pb-task:last-child{border-bottom:none;}
.pb-task-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:10px;font-weight:800;flex-shrink:0;margin-top:1px;}
.pb-once .pb-task-num{background:#fef2f2;color:#ef4444;}
.pb-weekly .pb-task-num{background:#fffbeb;color:#f59e0b;}
.pb-footer{background:var(--navy);border-radius:10px;padding:14px 18px;text-align:center;}
.pb-footer-brand{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:#fff;}
.pb-footer-tag{font-size:11px;color:rgba(255,255,255,.35);margin-top:3px;}
.btnp{background:var(--blue);color:#fff;}
.btnp:hover{background:var(--bb);}
.btno{background:#fff;border:2px solid var(--blue);color:var(--blue);}
.ch{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.chi{display:flex;align-items:flex-start;gap:11px;padding:8px 0;border-bottom:1px solid var(--grey);}
.chi:last-child{border-bottom:none;}
.chi input[type=checkbox]{margin-top:2px;width:16px;height:16px;cursor:pointer;accent-color:var(--blue);flex-shrink:0;}
.chi label{font-size:13px;cursor:pointer;line-height:1.5;}
.chi label.ck{text-decoration:line-through;color:var(--tl);}
.ci{width:34px;height:34px;background:var(--bp);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.ct{font-family:var(--fh);font-size:15px;font-weight:700;color:var(--navy);}
.ctrade{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--blue);font-family:var(--fh);}
.cs{font-size:11px;color:var(--tl);margin-top:1px;}
.csec{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--blue);margin:16px 0 7px;font-family:var(--fh);}
.cstat{text-align:center;background:var(--bp);border-radius:8px;padding:10px;}
.csn{font-family:var(--fh);font-size:22px;font-weight:800;color:var(--blue);}
.csl{font-size:10px;color:var(--tl);margin-top:2px;}
.cp{position:absolute;top:10px;right:10px;background:var(--blue);color:#fff;border:none;padding:3px 11px;border-radius:6px;font-size:11px;cursor:pointer;font-family:var(--fb);}
.cp:hover{background:var(--bb);}
.sb2{background:var(--grey);border-left:3px solid var(--blue);border-radius:0 10px 10px 0;padding:14px 16px;margin-bottom:10px;position:relative;}
.slbl{font-size:11px;color:#7a8fa6;margin-top:3px;}
.sl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--blue);margin-bottom:6px;font-family:var(--fh);}
.st{font-size:13px;line-height:1.75;color:var(--tx);white-space:pre-wrap;}
.stit{font-weight:600;color:var(--navy);margin-bottom:3px;font-family:var(--fh);font-size:14px;}
.tm{color:var(--tl);font-size:12px;}
.call-stage-btn{flex:1;padding:10px 8px;border:none;background:transparent;color:rgba(255,255,255,.35);font-size:10.5px;font-weight:600;cursor:pointer;text-align:center;font-family:var(--fh);letter-spacing:.3px;border-right:1px solid rgba(255,255,255,.08);transition:all .2s;line-height:1.3;}
.call-stage-btn:last-child{border-right:none;}
.call-stage-btn.active{background:var(--blue);color:#fff;}
.call-stage-btn:hover:not(.active){color:rgba(255,255,255,.7);}
.call-stage-panel{display:none;}
.call-stage-panel.active{display:block;}
.call-stages{display:flex;align-items:center;gap:0;margin-bottom:20px;background:var(--navy);border-radius:10px;overflow:hidden;}
.call-stages{flex-wrap:wrap;}
.disc-q{background:#fff;border:1.5px solid var(--gm);border-radius:9px;padding:12px 16px;margin-bottom:7px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:10px;transition:all .15s;}
.disc-q:hover{border-color:var(--blue);background:var(--bp);}
.disc-q-txt{font-size:13px;color:var(--tx);font-style:italic;flex:1;}
.disc-q-copy{background:var(--blue);color:#fff;border:none;padding:3px 9px;border-radius:5px;font-size:11px;cursor:pointer;flex-shrink:0;font-family:var(--fb);}
.disc-q-copy{background:var(--blue);color:#fff;border:none;padding:3px 9px;border-radius:5px;font-size:11px;cursor:pointer;flex-shrink:0;font-family:var(--fb);}
.disc-q-txt{font-size:13px;color:var(--tx);font-style:italic;flex:1;}
.rclay{display:flex;gap:7px;margin-bottom:14px;}
.rclb{flex:1;padding:8px;border:2px solid var(--gm);border-radius:8px;cursor:pointer;background:#fff;font-size:11.5px;font-weight:500;color:var(--tl);text-align:center;font-family:var(--fb);}
.rclb.on,.rclb:hover{border-color:var(--blue);color:var(--blue);}

/* ── DASHBOARD ── */
.dash-tier-row{display:flex;align-items:center;gap:12px;padding:9px 0;border-bottom:1px solid var(--grey);}
.dash-tier-row:last-child{border-bottom:none;}
.dash-tier-row.featured .dash-tier-name{color:var(--blue);}
.dash-tier-info{flex:1;min-width:0;}
.dash-tier-name{font-size:12.5px;font-weight:600;color:var(--navy);}
.dash-tier-price{font-size:10.5px;color:var(--tl);}
.dash-tier-controls{display:flex;align-items:center;gap:8px;}
.dash-tier-btn{width:24px;height:24px;border-radius:6px;border:1.5px solid var(--gm);background:#fff;cursor:pointer;font-size:14px;font-weight:700;color:var(--tl);display:flex;align-items:center;justify-content:center;line-height:1;transition:all .12s;}
.dash-tier-btn:hover{border-color:var(--blue);color:var(--blue);}
.dash-tier-count{font-family:var(--fh);font-size:18px;font-weight:800;color:var(--navy);min-width:28px;text-align:center;}
.dash-tier-sub{font-size:11px;font-weight:600;color:var(--tl);min-width:70px;text-align:right;}
.dash-pipe-row{display:flex;align-items:center;gap:10px;padding:7px 10px;border-radius:9px;background:var(--grey);margin-bottom:2px;}
.dash-pipe-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.dash-pipe-label{flex:1;font-size:12px;font-weight:600;color:var(--navy);}
.dash-pipe-controls{display:flex;align-items:center;gap:7px;}
.dash-pipe-btn{width:22px;height:22px;border-radius:5px;border:1.5px solid var(--gm);background:#fff;cursor:pointer;font-size:13px;font-weight:700;color:var(--tl);line-height:1;transition:all .12s;}
.dash-pipe-btn:hover{border-color:var(--blue);color:var(--blue);}
.dash-pipe-num{font-family:var(--fh);font-size:16px;font-weight:800;color:var(--navy);min-width:26px;text-align:center;}
.dash-pipe-rate{font-size:10px;font-weight:600;color:var(--tl);min-width:72px;text-align:right;}
.dash-pipe-arrow{text-align:center;color:var(--gm);font-size:14px;line-height:1;margin:1px 0;}
.dash-focus-panel{display:flex;align-items:center;gap:0;border-radius:11px;background:var(--grey);overflow:hidden;}
.dash-focus-item{flex:1;padding:14px 12px;text-align:center;}
.dash-focus-num{font-family:var(--fh);font-size:28px;font-weight:800;color:var(--navy);line-height:1;}
.dash-focus-lbl{font-size:10px;color:var(--tl);line-height:1.3;margin-top:3px;}
.dash-focus-target{font-size:9.5px;color:var(--blue);font-weight:600;margin-top:4px;}
.dash-focus-divider{width:1px;background:var(--gm);align-self:stretch;}
.dash-launch-btn{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:10px;border:2px solid transparent;cursor:pointer;text-align:left;width:100%;transition:opacity .15s;}
.dash-launch-btn:hover{opacity:.85;}

.tr-track-intro{background:var(--grey);border-radius:12px;padding:16px 20px;margin-bottom:18px;}
.tr-track-badge{display:inline-block;padding:4px 14px;border-radius:20px;font-size:11px;font-weight:700;font-family:var(--fh);letter-spacing:.5px;margin-bottom:0;}
.tr-module{border:1.5px solid var(--gm);border-radius:13px;margin-bottom:10px;overflow:hidden;transition:border-color .2s;}
.tr-module:hover{border-color:#94a3b8;}
.tr-mod-header{padding:16px 20px;cursor:pointer;display:flex;align-items:center;gap:14px;background:#fff;transition:background .15s;}
.tr-mod-header:hover{background:var(--grey);}
.tr-mod-num{width:32px;height:32px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-family:var(--fh);font-size:13px;font-weight:800;flex-shrink:0;transition:all .2s;}
.tr-mod-info{flex:1;min-width:0;}
.tr-mod-title{font-family:var(--fh);font-size:14px;font-weight:700;color:var(--navy);}
.tr-mod-sub{font-size:11px;color:var(--tl);margin-top:2px;}
.tr-mod-status{flex-shrink:0;}
.tr-mod-arrow{font-size:14px;color:var(--tl);flex-shrink:0;transition:transform .2s;}
.tr-mod-body{display:none;padding:22px;border-top:1px solid var(--gm);background:var(--grey);}
.tr-badge{display:inline-block;padding:3px 10px;border-radius:6px;font-size:10px;font-weight:700;font-family:var(--fh);}
.tr-badge-todo{background:#f1f5f9;color:var(--tl);}
.tr-badge-done{background:#dcfce7;color:#166534;}
.tr-read-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--tl);font-family:var(--fh);margin-bottom:10px;}
.tr-read-block{background:#fff;border-radius:10px;padding:18px 20px;border:1px solid var(--gm);font-size:13px;line-height:1.75;color:var(--tx);}
.tr-read-section{font-family:var(--fh);font-size:12px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
.tr-ai-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#0c4a6e;font-family:var(--fh);margin-bottom:8px;}
.tr-ai-desc{font-size:12px;color:var(--tl);line-height:1.6;margin-bottom:12px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:11px 13px;}
.tr-prompt-box{background:var(--navy);border-radius:10px;padding:16px 18px;font-family:monospace;font-size:11.5px;line-height:1.8;color:#94a3b8;white-space:pre-wrap;max-height:280px;overflow-y:auto;margin-bottom:10px;cursor:text;}
.tr-copy-btn{padding:8px 18px;background:var(--blue);color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--fh);margin-right:8px;transition:all .15s;}
.tr-copy-btn:hover{background:var(--bb);}
.tr-done-btn{padding:8px 18px;background:#fff;border:2px solid var(--gr);color:#166534;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--fh);transition:all .15s;}
.tr-done-btn:hover{background:#f0fdf4;}
.tr-pkg-row{font-size:12.5px;color:var(--tx);padding:6px 0;border-bottom:1px solid var(--grey);}
.tr-pkg-row:last-child{border-bottom:none;}
.tr-pkg-row.featured{color:var(--blue);font-weight:700;}


/* ── CHECKLISTS ── */
.ck-card{background:#fff;border-radius:12px;padding:20px 24px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.06),0 3px 10px rgba(0,0,0,.04);}
.ck-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.ck-title{font-family:var(--fh);font-size:14px;font-weight:800;color:var(--navy);}
.ck-group{margin-bottom:14px;}
.ck-group-label{font-size:9.5px;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--blue);margin-bottom:7px;font-family:var(--fh);}
.ck-item{display:flex;align-items:center;gap:10px;padding:7px 10px;border-radius:7px;border:1px solid transparent;cursor:pointer;}
.ck-item:hover{background:var(--grey);border-color:var(--gm);}
.ck-item input[type=checkbox]{width:16px;height:16px;cursor:pointer;accent-color:var(--blue);flex-shrink:0;}
.ck-item label{font-size:13px;cursor:pointer;line-height:1.4;color:var(--tx);}
.ck-item label.ck{text-decoration:line-through;color:var(--tl);}
.ck-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.ck-progress{display:flex;align-items:center;gap:10px;margin-bottom:14px;padding:10px 14px;background:var(--grey);border-radius:9px;}
.ck-progress-nums{font-family:var(--fh);font-size:13px;font-weight:800;color:var(--navy);}
.ck-progress-bar{flex:1;height:6px;background:var(--gm);border-radius:3px;overflow:hidden;}
.ck-progress-fill{height:100%;background:var(--blue);border-radius:3px;transition:width .2s;}
.ck-progress-pct{font-size:11px;font-weight:700;color:var(--blue);font-family:var(--fh);white-space:nowrap;}
.ck-2col{display:grid;grid-template-columns:1fr 1fr;gap:0;}
.ck-item-sm{display:flex;align-items:center;gap:9px;padding:5px 8px;border-radius:6px;cursor:pointer;}
.ck-item-sm:hover{background:var(--grey);}
.ck-item-sm input[type=checkbox]{width:15px;height:15px;cursor:pointer;accent-color:var(--blue);flex-shrink:0;}
.ck-item-sm label{font-size:12.5px;cursor:pointer;line-height:1.35;color:var(--tx);}
.ck-item-sm label.ck{text-decoration:line-through;color:var(--tl);}
.info-field{margin-bottom:10px;}
.info-field-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--tl);margin-bottom:4px;font-family:var(--fh);display:block;}
.info-field input,.info-field textarea{width:100%;padding:7px 10px;border:1.5px solid var(--gm);border-radius:7px;font-size:13px;font-family:var(--fb);color:var(--tx);background:#fff;}
.info-field input:focus,.info-field textarea:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 2px rgba(45,155,218,.1);}
.info-field textarea{min-height:48px;resize:none;}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 16px;}
.info-copy-btn{width:100%;padding:9px;background:var(--navy);color:#fff;border:none;border-radius:8px;font-family:var(--fh);font-size:12px;font-weight:700;cursor:pointer;margin-top:4px;}
.info-copy-btn:hover{background:var(--nm);}
.plugin-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:5px;}
.plugin-tag{background:var(--bp);border:1px solid rgba(45,155,218,.2);color:var(--blue);font-size:10.5px;font-weight:600;padding:2px 8px;border-radius:5px;font-family:var(--fh);}
/* ── SOPs ── */
.stage-block{border:1.5px solid var(--gm);border-radius:11px;margin-bottom:12px;overflow:hidden;}
.stage-head{background:var(--nm);padding:12px 16px;display:flex;align-items:center;gap:10px;}
