function showSec(id,btn){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('active'));
  var el=document.getElementById(id);if(el)el.classList.add('active');
  if(btn&&btn.classList)btn.classList.add('active');
}
function showTab(pre,id,btn){
  document.querySelectorAll('[id^="'+pre+'-"]').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tb').forEach(b=>{if(b.closest('[id^="'+pre+'"]')||b.closest('.tbar')){}});
  var el=document.getElementById(pre+'-'+id);if(el)el.classList.add('active');
  if(btn)btn.closest('.tbar').querySelectorAll('.tb').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
}
function togO(h){var b=h.nextElementSibling,a=h.querySelector('.oa');if(b){b.classList.toggle('open');if(a)a.classList.toggle('open');}}
function togM(h){var b=h.nextElementSibling,a=h.querySelector('.ma');if(b){b.classList.toggle('open');if(a)a.classList.toggle('open');}}
function togA(h){var b=h.nextElementSibling,a=h.querySelector('.acc-arr');if(b){b.classList.toggle('open');if(a)a.classList.toggle('open');}}
function copyEl(id){var el=document.getElementById(id);if(!el)return;navigator.clipboard.writeText(el.innerText).then(()=>{var btn=el.parentNode.querySelector('.copy-btn');if(btn){var t=btn.textContent;btn.textContent='✓ Copied';setTimeout(()=>btn.textContent=t,2000);}});}
function setRole(r,btn){
  document.querySelectorAll('.role-btn').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  document.querySelectorAll('.nb').forEach(nb=>{
    if(r==='all')nb.classList.remove('hidden');
    else nb.classList.toggle('hidden',!nb.classList.contains('nb-'+r));
  });
}

