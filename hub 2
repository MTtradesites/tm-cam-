function orJumpStatus(status){
  if(!status||!orLeads.length)return;
  for(var i=orIdx+1;i<orLeads.length;i++){
    if(orLeads[i].status===status){orIdx=i;orTickles=[...(orLeads[i].auto||[])];orRenderLead();return;}
  }
  for(var j=0;j<orIdx;j++){
    if(orLeads[j].status===status){orIdx=j;orTickles=[...(orLeads[j].auto||[])];orRenderLead();return;}
  }
  orToast('No '+status+' leads found',false);
}


