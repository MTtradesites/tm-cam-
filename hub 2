var CL_TRACKER_URL = 'https://script.google.com/macros/s/AKfycbx2U-aaeutKXtB2UwomFJcVMgOz55YMuHHrcin_jQKBM7RcZ6i2A8-E40rF73Q5lfqWRQ/exec';

window.addEventListener('load', function(){
  try {
    var u = localStorage.getItem('cl_tracker_url');
    if(u){ CL_TRACKER_URL = u; var el = document.getElementById('cl-tracker-url'); if(el) el.value = u; }
  } catch(e){}
});

function clSaveUrl(){
  var u = (document.getElementById('cl-tracker-url') || {}).value || '';
  CL_TRACKER_URL = u.trim();
  try{ localStorage.setItem('cl_tracker_url', CL_TRACKER_URL); }catch(e){}
  clLoadClients();
}

function clLoadClients(){
  if(!CL_TRACKER_URL){ alert('Paste the Client Tracker Apps Script URL first.'); return; }
  var list = document.getElementById('cl-list');
  if(list) list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--tl);font-size:13px;">Loading clients...</div>';
  fetch(CL_TRACKER_URL + '?action=list')
    .then(function(r){ return r.json(); })
    .then(function(res){
      if(!res.ok || !res.clients) throw new Error(res.error || 'No data');
      clRenderClients(res.clients);
    })
    .catch(function(err){
      if(list) list.innerHTML = '<div style="padding:16px;background:#fef2f2;border-radius:8px;font-size:13px;color:var(--rd);">Error loading clients: ' + err.toString() + '</div>';
    });
}

function clRenderClients(clients){
  var list = document.getElementById('cl-list');
  if(!list) return;
  if(!clients.length){
    list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--tl);font-size:13px;">No active clients yet. Add your first client using the form below.</div>';
    return;
  }
  var html = '<div style="display:flex;flex-direction:column;gap:8px;">';
  clients.forEach(function(c){
    var statusColour = c.status === 'Active' ? '#f0fdf4' : c.status === 'At Risk' ? '#fef9c3' : '#fef2f2';
    var statusText = c.status === 'Active' ? '#166534' : c.status === 'At Risk' ? '#92400e' : '#991b1b';
    var postFlag = c.postsThisMonth === 'No' ? ' &#9888; Post due' : ' &#10003;';
    var repFlag = c.reportSent === 'No' ? ' &#9888; Report due' : ' &#10003;';
    html += '<div style="background:'+statusColour+';border-radius:10px;padding:14px 16px;border:1px solid var(--gm);">';
    html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">';
    html += '<div style="font-family:var(--fh);font-size:14px;font-weight:700;color:var(--navy);">'+c.name+'</div>';
    html += '<div style="display:flex;gap:8px;align-items:center;">';
    html += '<span style="font-size:10px;background:'+statusColour+';color:'+statusText+';border:1px solid '+statusText+';padding:2px 8px;border-radius:5px;font-family:var(--fh);font-weight:700;">'+c.status+'</span>';
    html += '<span style="font-size:11px;color:var(--tl);">Month '+c.monthNumber+'</span>';
    html += '</div></div>';
    html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;font-size:12px;">';
    html += '<div><span style="color:var(--tl);">Trade</span><div style="font-weight:600;">'+c.trade+'</div></div>';
    html += '<div><span style="color:var(--tl);">Package</span><div style="font-weight:600;">'+c.package+'</div></div>';
    html += '<div><span style="color:var(--tl);">Reviews</span><div style="font-weight:600;">'+c.reviewsStart+' &#8594; '+c.reviewsNow+'</div></div>';
    html += '<div><span style="color:var(--tl);">Next Report</span><div style="font-weight:600;">'+c.nextReportDue+'</div></div>';
    html += '</div>';
    html += '<div style="display:flex;gap:12px;margin-top:10px;font-size:12px;">';
    html += '<span style="color:'+(c.postsThisMonth==='Yes'?'var(--gr)':'var(--am)')+';">GMB Post:'+postFlag+'</span>';
    html += '<span style="color:'+(c.reportSent==='Yes'?'var(--gr)':'var(--am)')+';">Report:'+repFlag+'</span>';
    if(c.month3Conv && c.month3Conv !== 'N/A') html += '<span style="color:var(--blue);">Month 3: '+c.month3Conv+'</span>';
    html += '</div>';
    html += '</div>';
  });
  html += '</div>';
  list.innerHTML = html;
}

function clAddClient(){
  if(!CL_TRACKER_URL){ alert('Paste the Client Tracker URL first and click Save.'); return; }
  var name    = (document.getElementById('cl-add-name')    ||{}).value||'';
  var trade   = (document.getElementById('cl-add-trade')   ||{}).value||'';
  var contact = (document.getElementById('cl-add-contact') ||{}).value||'';
  var phone   = (document.getElementById('cl-add-phone')   ||{}).value||'';
  var pkg     = (document.getElementById('cl-add-pkg')     ||{}).value||'';
  var reviews = (document.getElementById('cl-add-reviews') ||{}).value||'0';
  var leadId  = (document.getElementById('cl-add-leadid')  ||{}).value||'';
  var status  = document.getElementById('cl-add-status');

  if(!name){ if(status){status.textContent='Enter a business name.';status.style.color='var(--rd)';status.style.display='block';} return; }

  if(status){status.textContent='Adding...';status.style.color='var(--tl)';status.style.display='block';}
  fetch(CL_TRACKER_URL, {
    method:'POST',
    headers:{'Content-Type':'text/plain'},
    body: JSON.stringify({action:'add',company:name,trade:trade,contact:contact,phone:phone,package:pkg,reviewCount:parseInt(reviews)||0,leadId:leadId})
  })
  .then(function(r){return r.json();})
  .then(function(res){
    if(res.ok){
      if(status){status.textContent='&#10003; Added! Client ID: '+(res.clientId||'');status.style.color='var(--gr)';}
      ['cl-add-name','cl-add-trade','cl-add-contact','cl-add-phone','cl-add-reviews','cl-add-leadid'].forEach(function(id){var el=document.getElementById(id);if(el)el.value='';});
      setTimeout(clLoadClients, 1000);
    } else { throw new Error(res.error); }
  })
  .catch(function(err){ if(status){status.textContent='Error: '+err.toString();status.style.color='var(--rd)';} });
}

