function orRenderLead(){
  var lead=orLeads[orIdx]; if(!lead) return;

  // Name + type
  document.getElementById('or-biz-name').textContent=lead.name;
  document.getElementById('or-biz-type').textContent=lead.type||'';

  // Stars row
  var sr=document.getElementById('or-stars-row'); sr.innerHTML='';
  if(lead.rating){
    var filled=Math.round(lead.rating);
    var stars='';
    for(var i=0;i<5;i++) stars+=i<filled?'\u2605':'\u2606';
    sr.innerHTML='<span class="or-stars" style="font-size:14px;">'+stars+'</span>'
      +'<span style="font-family:var(--fh);font-size:13px;font-weight:800;color:var(--navy);">'+lead.rating.toFixed(1)+'</span>'
      +'<span style="font-size:12px;color:var(--tl);">('+lead.reviews+' reviews)</span>';
  }

  // Address + hours
  var ah=document.getElementById('or-address-hours');
  var parts=[];
  if(lead.address) parts.push('\ud83d\udccd '+lead.address);
  if(lead.openStatus||lead.hours){
    var open=lead.openStatus||'';
    var hrs=lead.hours||'';
    var line='';
    if(open) line+=(open.toLowerCase().indexOf('open')>-1?'\ud83d\udfe2':'\ud83d\udd34')+' '+open;
    if(hrs) line+=(line?' \u00b7 ':'')+hrs;
    if(line) parts.push(line);
  }
  ah.textContent=parts.join('\n');
  ah.style.display=parts.length?'':'none';

  // Snippet
  var sn=document.getElementById('or-snippet');
  if(lead.snippet){sn.textContent='\u201c'+lead.snippet+'\u201d';sn.style.display='';}
  else sn.style.display='none';

  // Info rows — big, tap friendly
  var ir=document.getElementById('or-info-rows'); ir.innerHTML='';

  function mkRow(icon,text,link,copyVal,copyLbl){
    var row=document.createElement('div');
    row.style.cssText='display:flex;align-items:center;justify-content:space-between;background:var(--grey);border-radius:8px;padding:8px 12px;';
    var left=document.createElement('div');
    left.style.cssText='display:flex;align-items:center;gap:8px;min-width:0;flex:1;';
    left.innerHTML='<span style="font-size:14px;flex-shrink:0;">'+icon+'</span>';
    if(link){
      var a=document.createElement('a');
      a.href=link; a.target='_blank';
      a.style.cssText='font-size:13px;font-weight:600;color:var(--blue);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
      a.textContent=text;
      left.appendChild(a);
    } else {
      var sp=document.createElement('span');
      sp.style.cssText='font-size:13px;font-weight:600;color:var(--navy);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
      sp.textContent=text;
      left.appendChild(sp);
    }
    row.appendChild(left);
    if(copyVal){
      var cb=document.createElement('button');
      cb.className='or-copy';
      cb.style.cssText='padding:5px 14px;font-size:12px;font-weight:700;margin-left:8px;flex-shrink:0;';
      cb.textContent=copyLbl||'Copy';
      cb.onclick=function(){
        navigator.clipboard.writeText(copyVal).then(function(){
          cb.textContent='\u2713 Copied'; cb.style.background='var(--gr)';
          setTimeout(function(){cb.textContent=copyLbl||'Copy';cb.style.background='';},1800);
        }).catch(function(){orToast('Copy failed',false);});
      };
      row.appendChild(cb);
    }
    ir.appendChild(row);
  }

  if(lead.phone)  mkRow('\ud83d\udcde', lead.phone, null, lead.phone, 'Copy number');
  mkRow('\ud83d\udccd', 'Google listing', lead.gmb||null, lead.gmb, 'Copy GMB');
  if(lead.website) mkRow('\ud83c\udf10', lead.website.replace(/^https?:\/\//,'').replace(/\/$/,'').slice(0,38), lead.website, lead.website, 'Copy URL');

  // Badge
  orUpdateBadge(lead.status);

  // Composer
  orRenderPills(lead);
  orUpdateMsg();

  // Nav
  document.getElementById('or-prev').disabled=(orIdx===0);
  document.getElementById('or-next').disabled=(orIdx>=orLeads.length-1);
  document.getElementById('or-counter').textContent=(orIdx+1)+' / '+orLeads.length;

  orUpdateProgress();
  orFillGmbInput();
}

// ── Pills ──────────────────────────────────────────────────────────────────────
function orRenderPills(lead){
  var wrap=document.getElementById('or-pills'); wrap.innerHTML='';
  var cats={};
  var catOrder=[];
  OR_GAPS.forEach(function(g){
    if(!cats[g.cat]){cats[g.cat]=[];catOrder.push(g.cat);}
    cats[g.cat].push(g);
  });
  catOrder.forEach(function(cat){
    var lbl=document.createElement('div');lbl.className='or-pill-cat';lbl.textContent=cat;
    wrap.appendChild(lbl);
    var row=document.createElement('div');row.className='or-pill-row';
    cats[cat].forEach(function(g){
      var on=orTickles.indexOf(g.id)>-1;
      var isAuto=(lead.auto||[]).indexOf(g.id)>-1;
      var btn=document.createElement('button');
      btn.className='or-pill'+(on?' on':'');
      btn.id='orpill_'+g.id;
      btn.title=g.snippet;
      btn.textContent=g.label;
      if(isAuto){var d=document.createElement('span');d.className='or-dot';btn.appendChild(d);}
      btn.onclick=function(){
        var i=orTickles.indexOf(g.id);
        if(i>-1)orTickles.splice(i,1);else orTickles.push(g.id);
        btn.className='or-pill'+(orTickles.indexOf(g.id)>-1?' on':'');
        orUpdateMsg();
      };
      row.appendChild(btn);
    });
    wrap.appendChild(row);
  });
}

function orClearPills(){
  orTickles=[];
  document.querySelectorAll('.or-pill').forEach(function(p){p.className='or-pill';});
  orUpdateMsg();
}

function orUpdateMsg(){
