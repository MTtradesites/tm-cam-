function orNav(dir){
  var n=orIdx+dir;
  if(n<0||n>=orLeads.length)return;
  orIdx=n;
  orTickles=[...(orLeads[orIdx].auto||[])];
  orSaveSession();
  orRenderLead();
}

function orSetStatus(status){
  if(!orLeads[orIdx])return;
  orLeads[orIdx].status=status;
  orSaveSession();
  orUpdateBadge(status);
  orUpdateProgress();
  if(orIdx<orLeads.length-1){setTimeout(function(){orNav(1);},160);}
}

// ── Mark sent ──────────────────────────────────────────────────────────────────
function orMarkSent(){
  var lead=orLeads[orIdx]; if(!lead)return;
  var ta=document.getElementById('or-msg-ta');
  var msg=ta?ta.value:orBuildMsg(lead,orSavedName,orTickles);
  var entry={
    ts:new Date().toISOString(),
    setter:orSavedName,
    business:lead.name,
    type:lead.type,
    phone:lead.phone,
    gaps:orTickles.join(', '),
    message:msg,
    gmb:lead.gmb,
    status:'sent'
  };
  orLeads[orIdx].status='sent';
  orSaveSession();
  orLog.unshift(entry);
  try{localStorage.setItem('or_log',JSON.stringify(orLog.slice(0,500)));}catch(e){}
  orRenderLog();
  // Post to Google Sheets
  if(orWebhook){
    try{
      fetch(orWebhook,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(entry)});
    }catch(e){}
  }
  orUpdateBadge('sent');
  orUpdateProgress();
  orUpdateTargetCounts();
  orToast('\u2713 Sent & logged to Sheet');
  if(orIdx<orLeads.length-1){setTimeout(function(){orNav(1);},180);}
}

