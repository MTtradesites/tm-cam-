  var zEl=document.getElementById('dash-zooms-today');
  if(zEl)zEl.textContent=dashPipe.audits;
  var crEl=document.getElementById('dash-close-rate');
  if(crEl)crEl.textContent=dashPipe.audits>0?Math.round(dashPipe.closed/dashPipe.audits*100)+'%':'—';
