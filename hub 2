function extractColors(imgEl,callback){
  try{
    var canvas=document.createElement('canvas');canvas.width=50;canvas.height=50;
    var ctx=canvas.getContext('2d');ctx.drawImage(imgEl,0,0,50,50);
    var data=ctx.getImageData(0,0,50,50).data;
    var buckets={};
    for(var i=0;i<data.length;i+=4){
      var r=data[i],g=data[i+1],b=data[i+2],a=data[i+3];
      if(a<128)continue;if(r>230&&g>230&&b>230)continue;if(r<20&&g<20&&b<20)continue;
      var qr=Math.round(r/32)*32,qg=Math.round(g/32)*32,qb=Math.round(b/32)*32;
      var key=qr+','+qg+','+qb;buckets[key]=(buckets[key]||0)+1;
    }
    var sorted=Object.entries(buckets).sort((a,b)=>b[1]-a[1]);
    var colors=[],seen=[];
    sorted.forEach(function(entry){
      if(colors.length>=5)return;
      var parts=entry[0].split(',').map(Number);
      var hex='#'+parts.map(v=>v.toString(16).padStart(2,'0')).join('');
      var isDupe=seen.some(function(s){var sp=s.split(',').map(Number);return Math.abs(sp[0]-parts[0])<40&&Math.abs(sp[1]-parts[1])<40&&Math.abs(sp[2]-parts[2])<40;});
      if(!isDupe){colors.push(hex);seen.push(entry[0]);}
    });
    callback(colors);
  }catch(e){callback([]);}
}




